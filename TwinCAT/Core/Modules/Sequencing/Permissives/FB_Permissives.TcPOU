<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.12">
  <POU Name="FB_Permissives" Id="{3468ff58-4b50-4782-bf79-0df0256f5d2f}" SpecialFunc="None">
    <Declaration><![CDATA[{attribute 'OPC.UA.DA' := '1'}
FUNCTION_BLOCK FB_Permissives
VAR_INPUT
    {attribute 'OPC.UA.DA' := '1'}
    {attribute 'OPC.UA.DA.Access' := '1'}
    cfg           : ST_PermIntlk_cfg; // Configuration: name, bit descriptions, and bypass settings
END_VAR
VAR_OUTPUT
    {attribute 'OPC.UA.DA' := '1'}
    {attribute 'OPC.UA.DA.Access' := '1'}
    sts           : ST_PermIntlk_sts; // Computed status
END_VAR
VAR
    {attribute 'OPC.UA.DA' := '0'}
    i         : INT;
    localStatus : INT;
    _mappedReasons : INT;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// Clear local status at start of each cycle
localStatus := 0;

// Loop over bits 0 to 15
FOR i := 0 TO 15 DO
    // Check if bypass is active for this bit (bypass bits are in cfg)
    IF (cfg.BypassPermissives AND SHL(1, i)) <> 0 THEN
        // Bypassed: treat this bit as OK
        localStatus := localStatus OR SHL(1, i);
    ELSE
        // Check if the mapped reason bit is set (via MapReason method)
        IF (_mappedReasons AND SHL(1, i)) <> 0 THEN
            localStatus := localStatus OR SHL(1, i);
        END_IF;
    END_IF;
END_FOR

// Save computed status to output variable
sts.PermIntlk := localStatus;

// Overall status: if all 16 bits are OK then sts.OK is TRUE.
sts.OK := (localStatus = -1);

// Clear mapped reasons for next cycle
_mappedReasons := 0;]]></ST>
    </Implementation>
    <Method Name="MapReason" Id="{e4f8bccd-7fc7-4931-81a3-645e9e6399f7}">
      <Declaration><![CDATA[METHOD MapReason
VAR_INPUT
    nIndex       : INT;            // Permissive reason index (0..15)
    sDescription : STRING;         // Description for this permissive reason
    bValue       : BOOL;           // TRUE = good (OK), FALSE = bad (not OK)
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Validate index range
IF nIndex >= 0 AND nIndex <= 15 THEN
    // Store description for this reason
    cfg.Desc[nIndex] := sDescription;

    // Set or clear the corresponding bit in _mappedReasons
    IF bValue THEN
        _mappedReasons := _mappedReasons OR SHL(1, nIndex);
    ELSE
        _mappedReasons := _mappedReasons AND NOT SHL(1, nIndex);
    END_IF;
END_IF;]]></ST>
      </Implementation>
    </Method>
    <LineIds Name="FB_Permissives">
      <LineId Id="502" Count="20" />
      <LineId Id="39" Count="0" />
    </LineIds>
    <LineIds Name="FB_Permissives.MapReason">
      <LineId Id="1" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>