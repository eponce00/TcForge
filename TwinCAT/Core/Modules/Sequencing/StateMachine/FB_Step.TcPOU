<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.12">
  <POU Name="FB_Step" Id="{a1b2c3d4-e5f6-7890-abcd-ef1234567890}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Step
VAR_IN_OUT
    sm : FB_StateMachine;
END_VAR

VAR_INPUT
    nStep : DINT;
    nNextStep : DINT;
    nTimeout : DINT;
    sName : STRING(80);
END_VAR

VAR_OUTPUT
    Entry : BOOL;
    Execute : BOOL;
    Exiting : BOOL;
END_VAR

VAR
    _perms : FB_Permissives;
    _active : BOOL;
    _prevActive : BOOL;
    _permsSatisfied : BOOL;
    _permsEvalReady : BOOL;
    _exitDone : BOOL;
    _effectiveNextStep : DINT;
    _hasOverride : BOOL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[
// Evaluate permissives (unmapped bits automatically good)
_perms();
_permsSatisfied := _perms.sts.bOK;

// Check if this step is the active step in the state machine
_active := (sm.StepInfo.CurrentStep = nStep);

// Default next step unless overridden
IF NOT _hasOverride THEN
    _effectiveNextStep := nNextStep;
END_IF;

// Reset lifecycle outputs each scan
Entry := FALSE;
Execute := FALSE;
Exiting := FALSE;

IF _active THEN
    // Report step metadata to state machine for HMI visibility
    sm.ReportStepInfo(sName := sName, stPerms := _perms.cfg);

    IF NOT _prevActive THEN
        //---------------------------------------------------------------------
        // ENTRY: first scan this step is active
        //---------------------------------------------------------------------
        Entry := TRUE;
        _permsEvalReady := FALSE;
        _exitDone := FALSE;
        _hasOverride := FALSE;

    ELSIF NOT _permsEvalReady THEN
        //---------------------------------------------------------------------
        // First EXECUTE scan: perms are being mapped, eval next cycle
        //---------------------------------------------------------------------
        Execute := TRUE;
        _permsEvalReady := TRUE;

    ELSIF NOT _permsSatisfied THEN
        //---------------------------------------------------------------------
        // EXECUTE: waiting for all mapped permissives to be satisfied
        //---------------------------------------------------------------------
        IF NOT sm.Status.Faulted THEN
            Execute := TRUE;
        END_IF;

        // Timeout fault detection
        IF nTimeout > 0 AND sm.StepInfo.StepTimerSeconds > DINT_TO_REAL(nTimeout) THEN
            sm.SetStepFault(bFault := TRUE);
        END_IF;

    ELSIF NOT _exitDone THEN
        //---------------------------------------------------------------------
        // EXIT: all permissives satisfied, one-scan cleanup
        //---------------------------------------------------------------------
        Exiting := TRUE;
        _exitDone := TRUE;

    ELSE
        //---------------------------------------------------------------------
        // ADVANCE: post-exit, request next step from state machine
        //---------------------------------------------------------------------
        sm.SetNextStep(nStep := _effectiveNextStep);
    END_IF;

ELSE
    // Reset lifecycle tracking when step is not active
    _permsEvalReady := FALSE;
    _exitDone := FALSE;
    _hasOverride := FALSE;
END_IF;

_prevActive := _active;
]]></ST>
    </Implementation>
    <Folder Name="Public" Id="{f0b10001-0001-0001-0001-000000000001}" />
    <Method Name="MapPerm" Id="{b2c3d4e5-f6a7-8901-bcde-f12345678901}" FolderPath="Public\">
      <Declaration><![CDATA[METHOD MapPerm
VAR_INPUT
    nIndex : UDINT;
    sDescription : STRING;
    bValue : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_perms.MapInput(bitIndex := nIndex, inputValue := bValue);
_perms.cfg.aNames[nIndex] := sDescription;]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetNextStep" Id="{c3d4e5f6-a7b8-9012-cdef-123456789012}" FolderPath="Public\">
      <Declaration><![CDATA[METHOD SetNextStep
VAR_INPUT
    nStep : DINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_effectiveNextStep := nStep;
_hasOverride := TRUE;]]></ST>
      </Implementation>
    </Method>
    <LineIds Name="FB_Step">
      <LineId Id="1" Count="0" />
    </LineIds>
    <LineIds Name="FB_Step.MapPerm">
      <LineId Id="1" Count="0" />
    </LineIds>
    <LineIds Name="FB_Step.SetNextStep">
      <LineId Id="1" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>