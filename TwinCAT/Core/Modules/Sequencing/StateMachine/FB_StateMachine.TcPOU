<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.12">
  <POU Name="FB_StateMachine" Id="{7408693c-f749-4b9e-8684-bfcba9889df8}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_StateMachine
VAR_INPUT
    EnableIn : BOOL;
    cfgAutoRun : BOOL;
    inpBlockedCondition : DINT;
    inpStarvedCondition : DINT;
    inpSubmoduleFaulted : BOOL;
END_VAR

VAR_OUTPUT
    EnableOut : BOOL;
    outRetry : BOOL;
    Status : ST_SM_Status;
    Permissions : ST_SM_Permissions;
    StepInfo : ST_SM_StepInfo;
    StepPermCfg : ST_Permissive_Config;
    StepPermStatus : ST_Permissive_Status;
    ConditionStatus : ST_SM_Conditions;
END_VAR

VAR CONSTANT
    HOMING_MIN   : DINT := 1000; HOMING_MAX   : DINT := 1999;
    RUNNING_MIN  : DINT := 3000; RUNNING_MAX  : DINT := 3999;
    STOPPING_MIN : DINT := 2000; STOPPING_MAX : DINT := 2999;
    ABORTING_MIN : DINT := 5000; ABORTING_MAX : DINT := 5999;
    PAUSING_MIN  : DINT := 4000; PAUSING_MAX  : DINT := 4999;
    PROCEEDING_MIN : DINT := 6000; PROCEEDING_MAX : DINT := 6999;
END_VAR

VAR
    // Internal command request flags (set by methods, consumed by body)
    _abortRequested : BOOL;
    _completeStateRequested : BOOL;
    _homeRequested : BOOL;
    _pauseRequested : BOOL;
    _proceedRequested : BOOL;
    _startRequested : BOOL;
    _stopRequested : BOOL;
    RetryComplete : BOOL;
    
    // Timer
    StepTimer : TON;
    
    // Edge detection
    R_TRIG_1 : R_TRIG;
    R_TRIG_5 : R_TRIG;
    
    // Internal state tracking
    _previousState : E_SM_State;
    PreviousStep : DINT;
    TimerReset : BOOL;
    LsOdd : DINT;
    _returnState : E_SM_State;
    ReturnNextStep : DINT;
    
    // Permission handlers
    internalAutoIntlk : FB_Permissives;
    internalHomePerm : FB_Permissives;
    internalProceedPerm : FB_Permissives;
    internalStartPerm : FB_Permissives;
    
    // Temp variables
    permIndex : UDINT;
    stepIsZero : BOOL;
    seqDone : BOOL;
    
    // Source control
    bSourceLockedToProg : BOOL;
    
    // Step ownership (internal)
    _nextStep : DINT;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[
//-----------------------------------------------------------------------------
// Main Implementation
//-----------------------------------------------------------------------------
EnableOut := EnableIn;

// Only execute if enabled
IF EnableIn THEN
    //-------------------------------------------------------------------------
    // Process permissions for different states
    //-------------------------------------------------------------------------
    internalHomePerm();
    Permissions.HomePermOK := internalHomePerm.sts.bOK;
    
    internalStartPerm();
    Permissions.StartPermOK := internalStartPerm.sts.bOK;
    
    internalProceedPerm();
    Permissions.ProceedPermOK := internalProceedPerm.sts.bOK;
    
    internalAutoIntlk();
    Permissions.AutoIntlkOK := internalAutoIntlk.sts.bOK;
    
    //-------------------------------------------------------------------------
    // Ready state calculations
    //-------------------------------------------------------------------------
    Status.ReadyToHome := (Status.State = E_SM_State.STOPPED OR Status.State = E_SM_State.ABORTED) AND 
                          Permissions.HomePermOK AND 
                          Permissions.AutoIntlkOK;
    
    Status.ReadyToStart := (Status.State = E_SM_State.HOMED OR Status.State = E_SM_State.COMPLETE) AND 
                          Permissions.StartPermOK AND 
                          Permissions.AutoIntlkOK AND 
                          NOT Status.AutoStartRequest;
    
    Status.ReadyToProceed := (Status.State = E_SM_State.PAUSED) AND 
                            Permissions.ProceedPermOK AND 
                            Permissions.AutoIntlkOK;

    //-------------------------------------------------------------------------
    // Auto-start request logic
    //-------------------------------------------------------------------------
    Status.AutoStartRequest := _startRequested AND NOT Permissions.StartPermOK;
    Status.AutoCycleRequest := cfgAutoRun AND (Status.State = E_SM_State.COMPLETE) AND NOT Permissions.StartPermOK;
    
    //-------------------------------------------------------------------------
    // Remember last state before change
    //-------------------------------------------------------------------------
    _previousState := Status.State;
    
    //-------------------------------------------------------------------------
    // Auto-run handling (internal - not from external command)
    //-------------------------------------------------------------------------
    IF cfgAutoRun AND Permissions.AutoIntlkOK AND Permissions.StartPermOK AND (Status.State = E_SM_State.COMPLETE) THEN
        _startRequested := TRUE;
    END_IF;
    
    //-------------------------------------------------------------------------
    // Sequence completion inference
    //-------------------------------------------------------------------------
    seqDone := _IsStepInStateRange(
        state := Status.State,
        nStep := StepInfo.CurrentStep
    ) AND (_nextStep = 0);

    R_TRIG_5(CLK := seqDone);
    IF R_TRIG_5.Q THEN
        _completeStateRequested := TRUE;
    END_IF;

    //-------------------------------------------------------------------------
    // State Transitions
    //-------------------------------------------------------------------------

    // Homing complete → Homed
    IF _completeStateRequested AND (Status.State = E_SM_State.HOMING) THEN
        _nextStep := 0;
        Status.State := E_SM_State.HOMED;
        _completeStateRequested := FALSE;
    END_IF;
    
    // Running complete → Complete
    IF _completeStateRequested AND (Status.State = E_SM_State.RUNNING) THEN
        _nextStep := 0;
        Status.State := E_SM_State.COMPLETE;
        _completeStateRequested := FALSE;
    END_IF;
    
    // Running + Stop → Stopping
    IF _stopRequested AND (Status.State = E_SM_State.RUNNING) THEN
        Status.State := E_SM_State.STOPPING;
    END_IF;
    
    // Stopping complete → Stopped
    IF _completeStateRequested AND (Status.State = E_SM_State.STOPPING) THEN
        _nextStep := 0;
        Status.State := E_SM_State.STOPPED;
        _completeStateRequested := FALSE;
    END_IF;
    
    // Aborting complete → Aborted
    IF _completeStateRequested AND (Status.State = E_SM_State.ABORTING) THEN
        _nextStep := 0;
        Status.State := E_SM_State.ABORTED;
        _completeStateRequested := FALSE;
    END_IF;
    
    // Active → Pausing
    IF _pauseRequested AND (
        Status.State = E_SM_State.HOMING OR Status.State = E_SM_State.STOPPING OR 
        Status.State = E_SM_State.ABORTING OR Status.State = E_SM_State.HOMED OR 
        Status.State = E_SM_State.COMPLETE OR Status.State = E_SM_State.PROCEEDING OR 
        Status.State = E_SM_State.RUNNING) THEN
        
        // Remember state + step for resume after Proceed (for mid-sequence paused only)
        IF NOT (Status.State = E_SM_State.HOMED OR Status.State = E_SM_State.COMPLETE OR Status.State = E_SM_State.PROCEEDING) THEN
            _returnState := Status.State;
            ReturnNextStep := StepInfo.CurrentStep;  // resume re-enters same step
        END_IF;
        
        Status.State := E_SM_State.PAUSING;
        _nextStep := 0;
    END_IF;
    
    // Pausing complete → Paused
    IF _completeStateRequested AND (Status.State = E_SM_State.PAUSING) THEN
        _nextStep := 0;
        Status.State := E_SM_State.PAUSED;
        _completeStateRequested := FALSE;
    END_IF;
    
    // Proceeding complete → return to state before pause, re-enter the paused step
    IF _completeStateRequested AND (Status.State = E_SM_State.PROCEEDING) THEN
        _nextStep := ReturnNextStep;
        Status.State := _returnState;
        _completeStateRequested := FALSE;
    END_IF;
    
    // Homed/Complete + Start → Running
    IF (_startRequested OR 
        (Status.AutoStartRequest AND Permissions.StartPermOK AND Permissions.AutoIntlkOK)) AND 
        (Status.State = E_SM_State.HOMED OR Status.State = E_SM_State.COMPLETE) THEN
        _nextStep := 0;
        Status.State := E_SM_State.RUNNING;
        _startRequested := FALSE;
    END_IF;
    
    // Homed + Stop → Stopped
    IF _stopRequested AND (Status.State = E_SM_State.HOMED) THEN
        _nextStep := 0;
        Status.State := E_SM_State.STOPPED;
    END_IF;
    
    // Complete + Stop → Stopped
    IF _stopRequested AND (Status.State = E_SM_State.COMPLETE) THEN
        _nextStep := 0;
        Status.State := E_SM_State.STOPPED;
    END_IF;
    
    // Stopped/Aborted + Home → Homing
    IF _homeRequested AND (Status.State = E_SM_State.STOPPED OR Status.State = E_SM_State.ABORTED) THEN
        _nextStep := 0;
        Status.State := E_SM_State.HOMING;
    END_IF;
    
    // Paused + Proceed → Proceeding
    IF _proceedRequested AND (Status.State = E_SM_State.PAUSED) THEN
        _nextStep := 0;
        Status.State := E_SM_State.PROCEEDING;
    END_IF;
    
    // Abort (from any state except Stopped/Aborted/Aborting)
    IF _abortRequested AND NOT (Status.State = E_SM_State.STOPPED OR Status.State = E_SM_State.ABORTED OR Status.State = E_SM_State.ABORTING) THEN
        _nextStep := 0;
        Status.State := E_SM_State.ABORTING;
    END_IF;
    
    //-------------------------------------------------------------------------
    // Track state changes
    //-------------------------------------------------------------------------
    IF Status.State <> _previousState THEN
        Status.LastState := _previousState;
    END_IF;
    
    //-------------------------------------------------------------------------
    // Derived status flags
    //-------------------------------------------------------------------------
    Status.WaitingState := (Status.State = E_SM_State.HOMED) OR (Status.State = E_SM_State.COMPLETE) OR 
                           (Status.State = E_SM_State.STOPPED) OR (Status.State = E_SM_State.PAUSED) OR 
                           (Status.State = E_SM_State.ABORTED);
    Status.ActiveState  := (Status.State = E_SM_State.HOMING) OR (Status.State = E_SM_State.RUNNING) OR 
                           (Status.State = E_SM_State.STOPPING) OR (Status.State = E_SM_State.PAUSING) OR 
                           (Status.State = E_SM_State.PROCEEDING) OR (Status.State = E_SM_State.ABORTING);

    //-------------------------------------------------------------------------
    // Step and timer management
    //-------------------------------------------------------------------------
    
    // Reset timer and clear step name when transitioning to step 0
    stepIsZero := (StepInfo.CurrentStep = 0);
    R_TRIG_1(CLK := stepIsZero);
    IF R_TRIG_1.Q THEN
        StepInfo.CurrentStepName := '';
        _ClearStepPermissives();
        TimerReset := TRUE;
        StepTimer(IN := FALSE, PT := T#99H);
        StepInfo.StepTimerSeconds := 0.0;
    END_IF;
    
    // Auto-initialize first step when entering an active state
    IF StepInfo.CurrentStep = 0 AND Status.ActiveState THEN
        _nextStep := _GetFirstStepForState(state := Status.State);
    END_IF;
    
    // Detect step change and update
    IF StepInfo.CurrentStep <> _nextStep THEN
        PreviousStep := StepInfo.CurrentStep;
        StepInfo.CurrentStep := _nextStep;
        TimerReset := TRUE;
        StepTimer(IN := FALSE, PT := T#99H);
        StepInfo.StepTimerSeconds := 0.0;
    END_IF;
    
    StepInfo.NextStep := _nextStep;
    
    // Step timer logic
    IF NOT (Status.State = E_SM_State.PAUSED) OR ((Status.State = E_SM_State.PAUSED) AND _completeStateRequested) THEN
        IF TimerReset THEN
            StepTimer(IN := FALSE, PT := T#99H);
            StepInfo.StepTimerSeconds := 0.0;
            TimerReset := FALSE;
        ELSE
            StepTimer(IN := TRUE, PT := T#99H);
            StepInfo.StepTimerSeconds := UDINT_TO_REAL(TIME_TO_UDINT(StepTimer.ET)) / 1000.0;
        END_IF;
    ELSE
        StepTimer(IN := FALSE, PT := T#99H);
    END_IF;
    
    //-------------------------------------------------------------------------
    // Fault detection
    //-------------------------------------------------------------------------
    LsOdd := StepInfo.CurrentStep MOD 2;
    Status.Faulted := LsOdd <> 0;
    Status.SubmoduleFaulted := inpSubmoduleFaulted;
    
    //-------------------------------------------------------------------------
    // Retry logic
    //-------------------------------------------------------------------------
    IF RetryComplete THEN
        outRetry := FALSE;
        RetryComplete := FALSE;
    END_IF;
    
    IF outRetry THEN
        RetryComplete := TRUE;
    END_IF;
    
    IF outRetry AND Status.Faulted THEN
        // Roll back to previous (even, non-faulted) step to re-enter it
        _nextStep := StepInfo.CurrentStep - 1;
    END_IF;
    
    //-------------------------------------------------------------------------
    // Blocked and Starved condition handling for OEE
    //-------------------------------------------------------------------------
    IF inpBlockedCondition = 0 THEN
        ConditionStatus.Blocked := 0;
    END_IF;
    
    IF inpBlockedCondition <> 0 AND 
       (Status.State = E_SM_State.RUNNING OR Status.State = E_SM_State.STOPPING OR Status.State = E_SM_State.COMPLETE OR 
        (Status.State = E_SM_State.HOMED AND Status.AutoStartRequest)) THEN
        ConditionStatus.Blocked := inpBlockedCondition;
        Status.Blocked := TRUE;
        inpBlockedCondition := 0;
    END_IF;
    
    IF inpStarvedCondition = 0 THEN
        ConditionStatus.Starved := 0;
    END_IF;
    
    IF inpStarvedCondition <> 0 AND 
       (Status.State = E_SM_State.RUNNING OR Status.State = E_SM_State.STOPPING OR Status.State = E_SM_State.COMPLETE OR 
        (Status.State = E_SM_State.HOMED AND Status.AutoStartRequest)) THEN
        ConditionStatus.Starved := inpStarvedCondition;
        Status.Starved := TRUE;
        inpStarvedCondition := 0;
    END_IF;
    
ELSE
    // Reset command requests when disabled
    _startRequested := FALSE;
    _stopRequested := FALSE;
    _homeRequested := FALSE;
    _abortRequested := FALSE;
    _pauseRequested := FALSE;
    _proceedRequested := FALSE;
    _completeStateRequested := FALSE;
    StepInfo.CurrentStepName := '';
        _ClearStepPermissives();
END_IF;
]]></ST>
    </Implementation>
    <Folder Name="Public" Id="{f0c10001-0001-0001-0001-000000000001}" />
    <Folder Name="Internal" Id="{f0c10002-0001-0001-0001-000000000002}" />
        <Folder Name="Private" Id="{f0c10003-0001-0001-0001-000000000003}" />
        <Method Name="_ClearStepPermissives" Id="{d4e5f6a7-b8c9-0123-def0-123456789abf}" FolderPath="Private\">
            <Declaration><![CDATA[METHOD PRIVATE _ClearStepPermissives]]></Declaration>
            <Implementation>
                <ST><![CDATA[StepPermCfg.nBypassable := 0;
StepPermStatus.bOK := FALSE;
StepPermStatus.nPermissives := 0;
StepPermStatus.nBypassMask := 0;
StepPermStatus.nFirstFailureBitIndex := 999;

FOR permIndex := 0 TO 63 DO
        StepPermCfg.aNames[permIndex] := '';
        StepPermStatus.aFaceplates[permIndex].name := '';
        StepPermStatus.aFaceplates[permIndex].stsOK := FALSE;
        StepPermStatus.aFaceplates[permIndex].stsMapped := FALSE;
        StepPermStatus.aFaceplates[permIndex].stsBypassed := FALSE;
        StepPermStatus.aFaceplates[permIndex].cfgBypassable := FALSE;
END_FOR;]]></ST>
            </Implementation>
        </Method>
        <Method Name="_GetFirstStepForState" Id="{d4e5f6a7-b8c9-0123-def0-123456789ac0}" FolderPath="Private\">
            <Declaration><![CDATA[METHOD PRIVATE _GetFirstStepForState : DINT
VAR_INPUT
        state : E_SM_State;
END_VAR]]></Declaration>
            <Implementation>
                <ST><![CDATA[CASE state OF
        E_SM_State.HOMING:     _GetFirstStepForState := HOMING_MIN;
        E_SM_State.RUNNING:    _GetFirstStepForState := RUNNING_MIN;
        E_SM_State.STOPPING:   _GetFirstStepForState := STOPPING_MIN;
        E_SM_State.ABORTING:   _GetFirstStepForState := ABORTING_MIN;
        E_SM_State.PAUSING:    _GetFirstStepForState := PAUSING_MIN;
        E_SM_State.PROCEEDING: _GetFirstStepForState := PROCEEDING_MIN;
ELSE
        _GetFirstStepForState := 0;
END_CASE;]]></ST>
            </Implementation>
        </Method>
        <Method Name="_GetLastStepForState" Id="{d4e5f6a7-b8c9-0123-def0-123456789ac1}" FolderPath="Private\">
            <Declaration><![CDATA[METHOD PRIVATE _GetLastStepForState : DINT
VAR_INPUT
        state : E_SM_State;
END_VAR]]></Declaration>
            <Implementation>
                <ST><![CDATA[CASE state OF
        E_SM_State.HOMING:     _GetLastStepForState := HOMING_MAX;
        E_SM_State.RUNNING:    _GetLastStepForState := RUNNING_MAX;
        E_SM_State.STOPPING:   _GetLastStepForState := STOPPING_MAX;
        E_SM_State.ABORTING:   _GetLastStepForState := ABORTING_MAX;
        E_SM_State.PAUSING:    _GetLastStepForState := PAUSING_MAX;
        E_SM_State.PROCEEDING: _GetLastStepForState := PROCEEDING_MAX;
ELSE
        _GetLastStepForState := 0;
END_CASE;]]></ST>
            </Implementation>
        </Method>
        <Method Name="_IsStepInStateRange" Id="{d4e5f6a7-b8c9-0123-def0-123456789ac2}" FolderPath="Private\">
            <Declaration><![CDATA[METHOD PRIVATE _IsStepInStateRange : BOOL
VAR_INPUT
        state : E_SM_State;
        nStep : DINT;
END_VAR]]></Declaration>
            <Implementation>
                <ST><![CDATA[_IsStepInStateRange := (nStep >= _GetFirstStepForState(state := state)) AND
                                             (nStep <= _GetLastStepForState(state := state));]]></ST>
            </Implementation>
        </Method>
    <Method Name="Abort" Id="{c1234567-1234-1234-1234-12345678C001}" FolderPath="Public\">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Abort : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Safety command - skip source check, skip fault check
IF Status.State = E_SM_State.STOPPED OR Status.State = E_SM_State.ABORTED OR Status.State = E_SM_State.ABORTING THEN
    Abort := E_RpcMethodResponse.REJECTED_WRONG_STATE;
    RETURN;
END_IF;

// Execute - clear other requests, set abort
_startRequested := FALSE;
_stopRequested := FALSE;
_homeRequested := FALSE;
_pauseRequested := FALSE;
_proceedRequested := FALSE;
_completeStateRequested := FALSE;
_abortRequested := TRUE;
Abort := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Home" Id="{c1234567-1234-1234-1234-12345678C002}" FolderPath="Public\">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Home : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Common validation
Home := F_ValidateRequester(eRequester, bSourceLockedToProg, Status.Faulted, FALSE, FALSE);
IF Home <> E_RpcMethodResponse.ACCEPTED THEN RETURN; END_IF;

// State check
IF NOT (Status.State = E_SM_State.STOPPED OR Status.State = E_SM_State.ABORTED) THEN
    Home := E_RpcMethodResponse.REJECTED_WRONG_STATE;
    RETURN;
END_IF;

// Permission check
IF NOT Permissions.HomePermOK THEN
    Home := E_RpcMethodResponse.REJECTED_PERMISSIVE_NOT_MET;
    RETURN;
END_IF;

// Interlock check
IF NOT Permissions.AutoIntlkOK THEN
    Home := E_RpcMethodResponse.REJECTED_INTERLOCKED;
    RETURN;
END_IF;

// Execute
_abortRequested := FALSE;
_pauseRequested := FALSE;
_proceedRequested := FALSE;
_startRequested := FALSE;
_stopRequested := FALSE;
_completeStateRequested := FALSE;
_homeRequested := TRUE;
Home := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="LockSource" Id="{c1234567-1234-1234-1234-12345678C008}" FolderPath="Public\">
      <Declaration><![CDATA[METHOD LockSource
VAR_INPUT
    bLock : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[bSourceLockedToProg := bLock;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Pause" Id="{c1234567-1234-1234-1234-12345678C003}" FolderPath="Public\">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Pause : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Common validation
Pause := F_ValidateRequester(eRequester, bSourceLockedToProg, Status.Faulted, FALSE, FALSE);
IF Pause <> E_RpcMethodResponse.ACCEPTED THEN RETURN; END_IF;

// State check
IF NOT (Status.State = E_SM_State.RUNNING) THEN
    Pause := E_RpcMethodResponse.REJECTED_WRONG_STATE;
    RETURN;
END_IF;

// Execute
_abortRequested := FALSE;
_homeRequested := FALSE;
_proceedRequested := FALSE;
_startRequested := FALSE;
_stopRequested := FALSE;
_completeStateRequested := FALSE;
_pauseRequested := TRUE;
Pause := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Proceed" Id="{c1234567-1234-1234-1234-12345678C004}" FolderPath="Public\">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Proceed : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Common validation
Proceed := F_ValidateRequester(eRequester, bSourceLockedToProg, Status.Faulted, FALSE, FALSE);
IF Proceed <> E_RpcMethodResponse.ACCEPTED THEN RETURN; END_IF;

// State check
IF NOT (Status.State = E_SM_State.PAUSED) THEN
    Proceed := E_RpcMethodResponse.REJECTED_WRONG_STATE;
    RETURN;
END_IF;

// Permission check
IF NOT Permissions.ProceedPermOK THEN
    Proceed := E_RpcMethodResponse.REJECTED_PERMISSIVE_NOT_MET;
    RETURN;
END_IF;

// Interlock check
IF NOT Permissions.AutoIntlkOK THEN
    Proceed := E_RpcMethodResponse.REJECTED_INTERLOCKED;
    RETURN;
END_IF;

// Execute
_abortRequested := FALSE;
_homeRequested := FALSE;
_pauseRequested := FALSE;
_startRequested := FALSE;
_stopRequested := FALSE;
_completeStateRequested := FALSE;
_proceedRequested := TRUE;
Proceed := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Retry" Id="{c1234567-1234-1234-1234-12345678C005}" FolderPath="Public\">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Retry : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Common validation
Retry := F_ValidateRequester(eRequester, bSourceLockedToProg, Status.Faulted, FALSE, FALSE);
IF Retry <> E_RpcMethodResponse.ACCEPTED THEN RETURN; END_IF;

// Execute - set retry directly
outRetry := TRUE;
Retry := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Start" Id="{c1234567-1234-1234-1234-12345678C006}" FolderPath="Public\">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Start : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Common validation
Start := F_ValidateRequester(eRequester, bSourceLockedToProg, Status.Faulted, FALSE, FALSE);
IF Start <> E_RpcMethodResponse.ACCEPTED THEN RETURN; END_IF;

// State check
IF NOT (Status.State = E_SM_State.HOMED OR Status.State = E_SM_State.COMPLETE) THEN
    Start := E_RpcMethodResponse.REJECTED_WRONG_STATE;
    RETURN;
END_IF;

// Permission check
IF NOT Permissions.StartPermOK THEN
    Start := E_RpcMethodResponse.REJECTED_PERMISSIVE_NOT_MET;
    RETURN;
END_IF;

// Interlock check
IF NOT Permissions.AutoIntlkOK THEN
    Start := E_RpcMethodResponse.REJECTED_INTERLOCKED;
    RETURN;
END_IF;

// Execute
_abortRequested := FALSE;
_pauseRequested := FALSE;
_homeRequested := FALSE;
_proceedRequested := FALSE;
_stopRequested := FALSE;
_completeStateRequested := FALSE;
_startRequested := TRUE;
Start := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Stop" Id="{c1234567-1234-1234-1234-12345678C007}" FolderPath="Public\">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Stop : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Safety command - skip source check, skip fault check
IF Status.State = E_SM_State.STOPPED OR Status.State = E_SM_State.STOPPING THEN
    Stop := E_RpcMethodResponse.REJECTED_WRONG_STATE;
    RETURN;
END_IF;

// Execute
_abortRequested := FALSE;
_homeRequested := FALSE;
_proceedRequested := FALSE;
_startRequested := FALSE;
_pauseRequested := FALSE;
_completeStateRequested := FALSE;
_stopRequested := TRUE;
Stop := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetNextStep" Id="{d4e5f6a7-b8c9-0123-def0-123456789abc}" FolderPath="Internal\">
      <Declaration><![CDATA[// INTERNAL: used by FB_Step to advance the sequence. Not part of the user API.
METHOD INTERNAL SetNextStep
VAR_INPUT
    nStep : DINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_nextStep := nStep;]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetStepName" Id="{d4e5f6a7-b8c9-0123-def0-123456789abd}" FolderPath="Internal\">
      <Declaration><![CDATA[// INTERNAL: used by FB_Step to publish its name to StepInfo. Not part of the user API.
METHOD INTERNAL SetStepName
VAR_INPUT
    sName : STRING(40);
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[StepInfo.CurrentStepName := sName;]]></ST>
      </Implementation>
    </Method>
        <Method Name="SetStepPermissives" Id="{d4e5f6a7-b8c9-0123-def0-123456789abe}" FolderPath="Internal\">
            <Declaration><![CDATA[// INTERNAL: used by FB_Step to publish the active step permissive data for HMI / OPC.
METHOD INTERNAL SetStepPermissives
VAR_INPUT
        cfg : ST_Permissive_Config;
        sts : ST_Permissive_Status;
END_VAR]]></Declaration>
            <Implementation>
                <ST><![CDATA[StepPermCfg := cfg;
StepPermStatus := sts;]]></ST>
            </Implementation>
        </Method>
    <Method Name="SetStepFault" Id="{e5f6a7b8-c9d0-1234-ef01-23456789abcd}" FolderPath="Internal\">
      <Declaration><![CDATA[// INTERNAL: used by FB_Step to fault the current step (timeout, etc.).
// Faults by advancing to the next (odd) step number -- Status.Faulted derives
// from (CurrentStep MOD 2). Not part of the user API.
METHOD INTERNAL SetStepFault
VAR_INPUT
    bFault : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF bFault THEN
    _nextStep := StepInfo.CurrentStep + 1;
END_IF;]]></ST>
      </Implementation>
    </Method>
