<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.12">
  <POU Name="FB_StateMachine" Id="{7408693c-f749-4b9e-8684-bfcba9889df8}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_StateMachine
VAR_INPUT
    EnableIn : BOOL;
    cfgAutoRun : BOOL;
    inpAutoIntlk : INT := -1;
    inpBlockedCondition : DINT;
    inpHomePerm : INT := -1;
    inpProceedPerm : INT := -1;
    inpStartPerm : INT := -1;
    inpStarvedCondition : DINT;
    inpSubmoduleFaulted : BOOL;
END_VAR

VAR_OUTPUT
    EnableOut : BOOL;
    outRetry : BOOL;
    Status : ST_SM_Status;
    Permissions : ST_SM_Permissions;
    StepInfo : ST_SM_StepInfo;
    ConditionStatus : ST_SM_Conditions;
    ActiveStepInfo : ActiveStep;
END_VAR

VAR CONSTANT
    internalClearStep : ActiveStep;
    
    STATE_IDLE : INT := 0;
    STATE_RUNNING : INT := 1;
    STATE_STOPPING : INT := 2;
    STATE_HOMING : INT := 4;
    STATE_ABORTING : INT := 8;
    STATE_HOMED : INT := 16;
    STATE_STOPPED : INT := 32;
    STATE_ABORTED : INT := 64;
    STATE_COMPLETE : INT := 128;
    STATE_PAUSING : INT := 256;
    STATE_PAUSED : INT := 512;
    STATE_PROCEEDING : INT := 1024;

    HOMING_MIN   : DINT := 1000; HOMING_MAX   : DINT := 1999;
    RUNNING_MIN  : DINT := 3000; RUNNING_MAX  : DINT := 3999;
    STOPPING_MIN : DINT := 2000; STOPPING_MAX : DINT := 2999;
    ABORTING_MIN : DINT := 5000; ABORTING_MAX : DINT := 5999;
    PAUSING_MIN  : DINT := 4000; PAUSING_MAX  : DINT := 4999;
    PROCEEDING_MIN : DINT := 6000; PROCEEDING_MAX : DINT := 6999;
END_VAR

VAR
    // Internal command request tracking (set by methods)
    CommandsRequested : ST_SM_Commands;
    RetryComplete : BOOL;
    
    // Timer
    StepTimer : TON;
    
    // Edge detection
    R_TRIG_1 : R_TRIG;
    R_TRIG_2 : R_TRIG;
    R_TRIG_4 : R_TRIG;
    R_TRIG_5 : R_TRIG;
    
    // Internal state tracking
    PauseStep : ActiveStep;
    PreviousState : DINT;
    PreviousStep : DINT;
    TimerReset : BOOL;
    LsOdd : DINT;
    ReturnState : DINT;
    ReturnNextStep : DINT;
    
    // Permission handlers
    internalAutoIntlk : FB_Permissives;
    internalHomePerm : FB_Permissives;
    internalProceedPerm : FB_Permissives;
    internalStartPerm : FB_Permissives;
    
    // Temp variables
    stepIsZero : BOOL;
    transitionActive : BOOL;
    seqDone : BOOL;
    permIdx : INT;
    
    // Source control
    bSourceLockedToProg : BOOL;
    
    // Step ownership (internal)
    _activeStep : ActiveStep;
    _nextStep : DINT;
END_VAR

VAR_IN_OUT
    Commands : ST_SM_Commands;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[
//-----------------------------------------------------------------------------
// Main Implementation
//-----------------------------------------------------------------------------
EnableOut := EnableIn;

// Only execute if enabled
IF EnableIn THEN
    //-------------------------------------------------------------------------
    // Process permissions for different states
    //-------------------------------------------------------------------------
    
    // Home permission evaluation
    FOR permIdx := 0 TO 15 DO
        internalHomePerm.MapReason(
            nIndex := permIdx,
            sDescription := internalHomePerm.cfg.Desc[permIdx],
            bValue := (inpHomePerm AND SHL(1, permIdx)) <> 0
        );
    END_FOR;
    internalHomePerm();
    Permissions.HomePermOK := internalHomePerm.sts.OK;
    
    // Start permission evaluation
    FOR permIdx := 0 TO 15 DO
        internalStartPerm.MapReason(
            nIndex := permIdx,
            sDescription := internalStartPerm.cfg.Desc[permIdx],
            bValue := (inpStartPerm AND SHL(1, permIdx)) <> 0
        );
    END_FOR;
    internalStartPerm();
    Permissions.StartPermOK := internalStartPerm.sts.OK;
    
    // Proceed permission evaluation
    FOR permIdx := 0 TO 15 DO
        internalProceedPerm.MapReason(
            nIndex := permIdx,
            sDescription := internalProceedPerm.cfg.Desc[permIdx],
            bValue := (inpProceedPerm AND SHL(1, permIdx)) <> 0
        );
    END_FOR;
    internalProceedPerm();
    Permissions.ProceedPermOK := internalProceedPerm.sts.OK;
    
    // Auto interlock evaluation
    FOR permIdx := 0 TO 15 DO
        internalAutoIntlk.MapReason(
            nIndex := permIdx,
            sDescription := internalAutoIntlk.cfg.Desc[permIdx],
            bValue := (inpAutoIntlk AND SHL(1, permIdx)) <> 0
        );
    END_FOR;
    internalAutoIntlk();
    Permissions.AutoIntlkOK := internalAutoIntlk.sts.OK;
    
    //-------------------------------------------------------------------------
    // Ready state calculations
    //-------------------------------------------------------------------------
    
    // Ready to Home: Stopped or Aborted + Home permissions OK + Auto interlock OK
    Status.ReadyToHome := (Status.Stopped OR Status.Aborted) AND 
                          Permissions.HomePermOK AND 
                          Permissions.AutoIntlkOK;
    
    // Ready to Start: (Homed or Complete) + Start permissions OK + Auto interlock OK + Not auto-start requested
    Status.ReadyToStart := (Status.Homed OR Status.Complete) AND 
                          Permissions.StartPermOK AND 
                          Permissions.AutoIntlkOK AND 
                          NOT Status.AutoStartRequest;
    
    // Ready to Proceed: Paused + Proceed permissions OK + Auto interlock OK
    Status.ReadyToProceed := Status.Paused AND 
                            Permissions.ProceedPermOK AND 
                            Permissions.AutoIntlkOK;

    //-------------------------------------------------------------------------
    // Clear Active Step if in waiting state
    //-------------------------------------------------------------------------
    IF Status.Homed OR Status.Complete OR Status.Stopped OR Status.Aborted THEN
        _activeStep := internalClearStep;
    END_IF;
    
    // Clear pause step on proceeding or aborting
    transitionActive := Status.Proceeding OR Status.Aborting;
    R_TRIG_4(CLK := transitionActive);
    IF R_TRIG_4.Q THEN
        PauseStep := internalClearStep;
    END_IF;
    
    //-------------------------------------------------------------------------
    // Auto-start request logic
    //-------------------------------------------------------------------------
    
    // Auto start request handling
    Status.AutoStartRequest := CommandsRequested.Start AND NOT Permissions.StartPermOK;
    
    // Auto cycle request for auto-run when complete
    Status.AutoCycleRequest := cfgAutoRun AND Status.Complete AND NOT Permissions.StartPermOK;
    
    //-------------------------------------------------------------------------
    // Remember last state before change
    //-------------------------------------------------------------------------
    PreviousState := StepInfo.CurrentState;
    
    //-------------------------------------------------------------------------
    // Process command requests (only CompleteState from sequences)
    //-------------------------------------------------------------------------
    
    // Complete State Request (from sequence programs via Commands VAR_IN_OUT)
    IF Commands.CompleteState THEN
        CommandsRequested.CompleteState := TRUE;
        Commands.CompleteState := FALSE;
        CommandsRequested.Start := FALSE;
        CommandsRequested.Abort := FALSE;
        CommandsRequested.Pause := FALSE;
        CommandsRequested.Home := FALSE;
        CommandsRequested.Proceed := FALSE;
        CommandsRequested.Stop := FALSE;
    END_IF;
    
    // Auto-run handling (internal - not from external command)
    IF cfgAutoRun AND Permissions.AutoIntlkOK AND Permissions.StartPermOK AND Status.Complete THEN
        CommandsRequested.Start := TRUE;
    END_IF;
    
    //-------------------------------------------------------------------------
    // Sequence completion inference
    //-------------------------------------------------------------------------
    // If in an active state with a defined sequence range and the sequence
    // drives NextStep to 0 while the current step is within that state's
    // range, infer completion and trigger CompleteState internally.
    seqDone := FALSE;
    IF Status.Homing THEN
        seqDone := (StepInfo.CurrentStep >= HOMING_MIN) AND (StepInfo.CurrentStep <= HOMING_MAX) AND (_nextStep = 0);
    ELSIF Status.Running THEN
        seqDone := (StepInfo.CurrentStep >= RUNNING_MIN) AND (StepInfo.CurrentStep <= RUNNING_MAX) AND (_nextStep = 0);
    ELSIF Status.Stopping THEN
        seqDone := (StepInfo.CurrentStep >= STOPPING_MIN) AND (StepInfo.CurrentStep <= STOPPING_MAX) AND (_nextStep = 0);
    ELSIF Status.Aborting THEN
        seqDone := (StepInfo.CurrentStep >= ABORTING_MIN) AND (StepInfo.CurrentStep <= ABORTING_MAX) AND (_nextStep = 0);
    ELSIF Status.Pausing THEN
        seqDone := (StepInfo.CurrentStep >= PAUSING_MIN) AND (StepInfo.CurrentStep <= PAUSING_MAX) AND (_nextStep = 0);
    ELSIF Status.Proceeding THEN
        seqDone := (StepInfo.CurrentStep >= PROCEEDING_MIN) AND (StepInfo.CurrentStep <= PROCEEDING_MAX) AND (_nextStep = 0);
    END_IF;

    R_TRIG_5(CLK := seqDone);
    IF R_TRIG_5.Q THEN
        CommandsRequested.CompleteState := TRUE;
    END_IF;

    //-------------------------------------------------------------------------
    // State Transitions
    //-------------------------------------------------------------------------

    // Complete to Homed
    IF CommandsRequested.CompleteState AND Status.Homing THEN
        _nextStep := 0;
        StepInfo.CurrentState := STATE_HOMED;
        CommandsRequested.CompleteState := FALSE;  // Clear after transition
    END_IF;
    
    // Running to Complete
    IF CommandsRequested.CompleteState AND Status.Running THEN
        _nextStep := 0;
        StepInfo.CurrentState := STATE_COMPLETE;
        CommandsRequested.CompleteState := FALSE;  // Clear after transition
    END_IF;
    
    // Running to Stopping
    IF CommandsRequested.Stop AND Status.Running THEN
        StepInfo.CurrentState := STATE_STOPPING;
    END_IF;
    
    // Stopping to Stopped
    IF CommandsRequested.CompleteState AND Status.Stopping THEN
        _nextStep := 0;
        StepInfo.CurrentState := STATE_STOPPED;
        CommandsRequested.CompleteState := FALSE;  // Clear after transition
    END_IF;
    
    // Aborting to Aborted
    IF CommandsRequested.CompleteState AND Status.Aborting THEN
        _nextStep := 0;
        StepInfo.CurrentState := STATE_ABORTED;
        CommandsRequested.CompleteState := FALSE;  // Clear after transition
    END_IF;
    
    // Active State to Pausing
    // Handle state transitions to Pausing and remember the state to return to
    IF CommandsRequested.Pause AND (
        Status.Homing OR Status.Stopping OR Status.Aborting OR 
        Status.Homed OR Status.Complete OR Status.Proceeding OR Status.Running) THEN
        
        // Remember the current state and next step for later return
        IF NOT (Status.Homed OR Status.Complete OR Status.Proceeding) THEN
            ReturnState := StepInfo.CurrentState;
            ReturnNextStep := _nextStep;
        END_IF;
        
        // Save the current step for paused state
        IF NOT (Status.Homed OR Status.Complete OR Status.Proceeding) THEN
            PauseStep := _activeStep;
        ELSE
            PauseStep := internalClearStep;
        END_IF;
        
        // Transition to pausing state
        StepInfo.CurrentState := STATE_PAUSING;
        _nextStep := 0;
    END_IF;
    
    // Pausing to Paused
    IF CommandsRequested.CompleteState AND Status.Pausing THEN
        _nextStep := 0;
        StepInfo.CurrentState := STATE_PAUSED;
        CommandsRequested.CompleteState := FALSE;  // Clear after transition
    END_IF;
    
    // Proceeding to Step before Pausing
    IF CommandsRequested.CompleteState AND Status.Proceeding THEN
        _activeStep := PauseStep;
        _nextStep := ReturnNextStep;
        StepInfo.CurrentState := ReturnState;
        CommandsRequested.CompleteState := FALSE;  // Clear after transition
    END_IF;
    
    // Homed to Running
    IF (CommandsRequested.Start OR 
        (Status.AutoStartRequest AND Permissions.StartPermOK AND Permissions.AutoIntlkOK)) AND 
        (Status.Homed OR Status.Complete) THEN
        
        _nextStep := 0;
        StepInfo.CurrentState := STATE_RUNNING;
        CommandsRequested.Start := FALSE;
    END_IF;
    
    // Homed to Stopped
    IF CommandsRequested.Stop AND Status.Homed THEN
        _nextStep := 0;
        StepInfo.CurrentState := STATE_STOPPED;
    END_IF;
    
    // Complete to Stopped
    IF CommandsRequested.Stop AND Status.Complete THEN
        _nextStep := 0;
        StepInfo.CurrentState := STATE_STOPPED;
    END_IF;
    
    // Stopped or Aborted to Homing
    IF CommandsRequested.Home AND (Status.Stopped OR Status.Aborted) THEN
        _nextStep := 0;
        StepInfo.CurrentState := STATE_HOMING;
    END_IF;
    
    // Paused to Proceeding
    IF CommandsRequested.Proceed AND Status.Paused THEN
        _nextStep := 0;
        StepInfo.CurrentState := STATE_PROCEEDING;
    END_IF;
    
    // Abort (from any state except Stopped/Aborted/Aborting)
    IF CommandsRequested.Abort AND NOT (Status.Stopped OR Status.Aborted OR Status.Aborting) THEN
        _nextStep := 0;
        StepInfo.CurrentState := STATE_ABORTING;
    END_IF;
    
    //-------------------------------------------------------------------------
    // Save last state when changing
    //-------------------------------------------------------------------------
    IF StepInfo.CurrentState <> PreviousState THEN
        StepInfo.LastState := PreviousState;
    END_IF;
    
    //-------------------------------------------------------------------------
    // Update status flags based on current state
    //-------------------------------------------------------------------------
    // Reset all status flags first
    Status.Running := FALSE;
    Status.Stopping := FALSE;
    Status.Homing := FALSE;
    Status.Aborting := FALSE;
    Status.Homed := FALSE;
    Status.Stopped := FALSE;
    Status.Aborted := FALSE;
    Status.Complete := FALSE;
    Status.Pausing := FALSE;
    Status.Paused := FALSE;
    Status.Proceeding := FALSE;
    
    // Set corresponding status flag based on current state
    CASE StepInfo.CurrentState OF
        STATE_RUNNING:
            Status.Running := TRUE;
            StepInfo.StateString := 'Running';
        
        STATE_STOPPING:
            Status.Stopping := TRUE;
            StepInfo.StateString := 'Stopping';
        
        STATE_HOMING:
            Status.Homing := TRUE;
            StepInfo.StateString := 'Homing';
        
        STATE_ABORTING:
            Status.Aborting := TRUE;
            StepInfo.StateString := 'Aborting';
        
        STATE_HOMED:
            Status.Homed := TRUE;
            StepInfo.StateString := 'Homed';
        
        STATE_STOPPED:
            Status.Stopped := TRUE;
            StepInfo.StateString := 'Stopped';
        
        STATE_ABORTED:
            Status.Aborted := TRUE;
            StepInfo.StateString := 'Aborted';
        
        STATE_COMPLETE:
            Status.Complete := TRUE;
            StepInfo.StateString := 'Complete';
        
        STATE_PAUSING:
            Status.Pausing := TRUE;
            StepInfo.StateString := 'Pausing';
        
        STATE_PAUSED:
            Status.Paused := TRUE;
            StepInfo.StateString := 'Paused';
        
        STATE_PROCEEDING:
            Status.Proceeding := TRUE;
            StepInfo.StateString := 'Proceeding';
    END_CASE;
    
    // Set the active/waiting state flags
    Status.WaitingState := Status.Homed OR Status.Complete OR Status.Stopped OR Status.Paused OR Status.Aborted;
    Status.ActiveState := Status.Homing OR Status.Running OR Status.Stopping OR Status.Pausing OR Status.Proceeding OR Status.Aborting;
    
    // Set mode (0 = Manual, 1 = Automatic)
    IF Status.Stopped OR Status.Aborted OR Status.Paused THEN
        Status.Mode := 0;
        Status.Manual := TRUE;
        Status.Automatic := FALSE;
    ELSE
        Status.Mode := 1;
        Status.Manual := FALSE;
        Status.Automatic := TRUE;
    END_IF;

    //-------------------------------------------------------------------------
    // Step and timer management
    //-------------------------------------------------------------------------
    
    // Clear ActiveStep when transitioning to step 0 (when step becomes zero)
    stepIsZero := (StepInfo.CurrentStep = 0);
    R_TRIG_1(CLK := stepIsZero);
    IF R_TRIG_1.Q THEN
        _activeStep := internalClearStep;
        // Also reset timer when entering step 0 (state transitions)
        TimerReset := TRUE;
        StepTimer(IN := FALSE, PT := T#99H);
        StepInfo.StepTimerSeconds := 0.0;  // Immediately clear the timer output
    END_IF;
    
    // Auto-initialize first step when entering an active state
    IF StepInfo.CurrentStep = 0 AND Status.ActiveState THEN
        IF Status.Homing THEN
            _nextStep := HOMING_MIN;
        ELSIF Status.Running THEN
            _nextStep := RUNNING_MIN;
        ELSIF Status.Stopping THEN
            _nextStep := STOPPING_MIN;
        ELSIF Status.Aborting THEN
            _nextStep := ABORTING_MIN;
        ELSIF Status.Pausing THEN
            _nextStep := PAUSING_MIN;
        ELSIF Status.Proceeding THEN
            _nextStep := PROCEEDING_MIN;
        END_IF;
    END_IF;
    
    // Detect step change and update step - AFTER clearing logic
    IF StepInfo.CurrentStep <> _nextStep THEN
        // Store previous step for reference
        PreviousStep := StepInfo.CurrentStep;
        StepInfo.CurrentStep := _nextStep;
        TimerReset := TRUE;
        // Immediately reset timer when step changes
        StepTimer(IN := FALSE, PT := T#99H);
        StepInfo.StepTimerSeconds := 0.0;  // Immediately clear the timer output
    END_IF;
    
    // Synchronize shared ActiveStep.Step with internal step tracking - AFTER all step updates
    IF _activeStep.Step <> StepInfo.CurrentStep THEN
        _activeStep.Step := StepInfo.CurrentStep;
    END_IF;
    
    // Update StepInfo.NextStep output
    StepInfo.NextStep := _nextStep;
    
    // Step timer logic
    IF NOT Status.Paused OR (Status.Paused AND CommandsRequested.CompleteState) THEN
        IF TimerReset THEN
            // Keep timer reset for one scan, then clear flag
            StepTimer(IN := FALSE, PT := T#99H);
            StepInfo.StepTimerSeconds := 0.0;  // Ensure timer value is zero during reset
            TimerReset := FALSE;
        ELSE
            // Normal timer operation
            StepTimer(IN := TRUE, PT := T#99H);
            // Convert timer value to seconds only when not resetting
            StepInfo.StepTimerSeconds := UDINT_TO_REAL(TIME_TO_UDINT(StepTimer.ET)) / 1000.0;
        END_IF;
    ELSE
        StepTimer(IN := FALSE, PT := T#99H);
        // Don't update StepTimerSeconds when paused unless transitioning
    END_IF;
    
    //-------------------------------------------------------------------------
    // Fault detection
    //-------------------------------------------------------------------------
    
    // Check if step is odd (indicates fault)
    LsOdd := StepInfo.CurrentStep MOD 2;
    Status.Faulted := LsOdd <> 0;
    
    // Submodule fault handling
    Status.SubmoduleFaulted := inpSubmoduleFaulted;
    
    //-------------------------------------------------------------------------
    // Retry logic (set by Retry method, consumed here)
    //-------------------------------------------------------------------------
    
    // Retry command from command input (sequence programs)
    IF Commands.Retry THEN
        R_TRIG_2(CLK := TRUE);
        IF R_TRIG_2.Q THEN
            outRetry := TRUE;
        END_IF;
        Commands.Retry := FALSE;
    ELSE
        R_TRIG_2(CLK := FALSE);
    END_IF;
    
    // Ensure retry signal stays on for at least one scan
    IF RetryComplete THEN
        outRetry := FALSE;
        RetryComplete := FALSE;
    END_IF;
    
    IF outRetry THEN
        RetryComplete := TRUE;
    END_IF;
    
    // On retry, return faulted step (odd) to normal step (even)
    IF outRetry AND Status.Faulted THEN
        _nextStep := StepInfo.CurrentStep - 1;
        _activeStep.StatusStepFaulted := FALSE;
    END_IF;
    
    //-------------------------------------------------------------------------
    // Blocked and Starved condition handling for OEE
    //-------------------------------------------------------------------------
    
    // Reset blocked condition if not present
    IF inpBlockedCondition = 0 THEN
        ConditionStatus.Blocked := 0;
    END_IF;
    
    // Check for blocked condition in appropriate states
    IF inpBlockedCondition <> 0 AND 
       (Status.Running OR Status.Stopping OR Status.Complete OR 
        (Status.Homed AND Status.AutoStartRequest)) THEN
        
        ConditionStatus.Blocked := inpBlockedCondition;
        Status.Blocked := TRUE;
        inpBlockedCondition := 0;
    END_IF;
    
    // Reset starved condition if not present
    IF inpStarvedCondition = 0 THEN
        ConditionStatus.Starved := 0;
    END_IF;
    
    // Check for starved condition in appropriate states
    IF inpStarvedCondition <> 0 AND 
       (Status.Running OR Status.Stopping OR Status.Complete OR 
        (Status.Homed AND Status.AutoStartRequest)) THEN
        
        ConditionStatus.Starved := inpStarvedCondition;
        Status.Starved := TRUE;
        inpStarvedCondition := 0;
    END_IF;
    
    // Expose active step info for HMI
    ActiveStepInfo := _activeStep;
    
ELSE
    // Reset command requests when disabled
    CommandsRequested.Start := FALSE;
    CommandsRequested.Stop := FALSE;
    CommandsRequested.Home := FALSE;
    CommandsRequested.Abort := FALSE;
    CommandsRequested.Pause := FALSE;
    CommandsRequested.Proceed := FALSE;
    CommandsRequested.CompleteState := FALSE;
END_IF;
]]></ST>
    </Implementation>
    <Method Name="Abort" Id="{c1234567-1234-1234-1234-12345678C001}">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Abort : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Safety command - skip source check, skip fault check
IF Status.Stopped OR Status.Aborted OR Status.Aborting THEN
    Abort := E_RpcMethodResponse.REJECTED_WRONG_STATE;
    RETURN;
END_IF;

// Execute - clear other requests, set abort
CommandsRequested.Start := FALSE;
CommandsRequested.Stop := FALSE;
CommandsRequested.Home := FALSE;
CommandsRequested.Pause := FALSE;
CommandsRequested.Proceed := FALSE;
CommandsRequested.CompleteState := FALSE;
CommandsRequested.Abort := TRUE;
Abort := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Home" Id="{c1234567-1234-1234-1234-12345678C002}">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Home : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Common validation
Home := F_ValidateRequester(eRequester, bSourceLockedToProg, Status.Faulted, FALSE, FALSE);
IF Home <> E_RpcMethodResponse.ACCEPTED THEN RETURN; END_IF;

// State check
IF NOT (Status.Stopped OR Status.Aborted) THEN
    Home := E_RpcMethodResponse.REJECTED_WRONG_STATE;
    RETURN;
END_IF;

// Permission check
IF NOT Permissions.HomePermOK THEN
    Home := E_RpcMethodResponse.REJECTED_PERMISSIVE_NOT_MET;
    RETURN;
END_IF;

// Interlock check
IF NOT Permissions.AutoIntlkOK THEN
    Home := E_RpcMethodResponse.REJECTED_INTERLOCKED;
    RETURN;
END_IF;

// Execute
CommandsRequested.Abort := FALSE;
CommandsRequested.Pause := FALSE;
CommandsRequested.Proceed := FALSE;
CommandsRequested.Start := FALSE;
CommandsRequested.Stop := FALSE;
CommandsRequested.CompleteState := FALSE;
CommandsRequested.Home := TRUE;
Home := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="LockSource" Id="{c1234567-1234-1234-1234-12345678C008}">
      <Declaration><![CDATA[METHOD LockSource
VAR_INPUT
    bLock : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[bSourceLockedToProg := bLock;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Pause" Id="{c1234567-1234-1234-1234-12345678C003}">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Pause : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Common validation
Pause := F_ValidateRequester(eRequester, bSourceLockedToProg, Status.Faulted, FALSE, FALSE);
IF Pause <> E_RpcMethodResponse.ACCEPTED THEN RETURN; END_IF;

// State check
IF NOT Status.Running THEN
    Pause := E_RpcMethodResponse.REJECTED_WRONG_STATE;
    RETURN;
END_IF;

// Execute
CommandsRequested.Abort := FALSE;
CommandsRequested.Home := FALSE;
CommandsRequested.Proceed := FALSE;
CommandsRequested.Start := FALSE;
CommandsRequested.Stop := FALSE;
CommandsRequested.CompleteState := FALSE;
CommandsRequested.Pause := TRUE;
Pause := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Proceed" Id="{c1234567-1234-1234-1234-12345678C004}">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Proceed : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Common validation
Proceed := F_ValidateRequester(eRequester, bSourceLockedToProg, Status.Faulted, FALSE, FALSE);
IF Proceed <> E_RpcMethodResponse.ACCEPTED THEN RETURN; END_IF;

// State check
IF NOT Status.Paused THEN
    Proceed := E_RpcMethodResponse.REJECTED_WRONG_STATE;
    RETURN;
END_IF;

// Permission check
IF NOT Permissions.ProceedPermOK THEN
    Proceed := E_RpcMethodResponse.REJECTED_PERMISSIVE_NOT_MET;
    RETURN;
END_IF;

// Interlock check
IF NOT Permissions.AutoIntlkOK THEN
    Proceed := E_RpcMethodResponse.REJECTED_INTERLOCKED;
    RETURN;
END_IF;

// Execute
CommandsRequested.Abort := FALSE;
CommandsRequested.Home := FALSE;
CommandsRequested.Pause := FALSE;
CommandsRequested.Start := FALSE;
CommandsRequested.Stop := FALSE;
CommandsRequested.CompleteState := FALSE;
CommandsRequested.Proceed := TRUE;
Proceed := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Retry" Id="{c1234567-1234-1234-1234-12345678C005}">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Retry : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Common validation
Retry := F_ValidateRequester(eRequester, bSourceLockedToProg, Status.Faulted, FALSE, FALSE);
IF Retry <> E_RpcMethodResponse.ACCEPTED THEN RETURN; END_IF;

// Execute - set retry directly
outRetry := TRUE;
Retry := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Start" Id="{c1234567-1234-1234-1234-12345678C006}">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Start : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Common validation
Start := F_ValidateRequester(eRequester, bSourceLockedToProg, Status.Faulted, FALSE, FALSE);
IF Start <> E_RpcMethodResponse.ACCEPTED THEN RETURN; END_IF;

// State check
IF NOT (Status.Homed OR Status.Complete) THEN
    Start := E_RpcMethodResponse.REJECTED_WRONG_STATE;
    RETURN;
END_IF;

// Permission check
IF NOT Permissions.StartPermOK THEN
    Start := E_RpcMethodResponse.REJECTED_PERMISSIVE_NOT_MET;
    RETURN;
END_IF;

// Interlock check
IF NOT Permissions.AutoIntlkOK THEN
    Start := E_RpcMethodResponse.REJECTED_INTERLOCKED;
    RETURN;
END_IF;

// Execute
CommandsRequested.Abort := FALSE;
CommandsRequested.Pause := FALSE;
CommandsRequested.Home := FALSE;
CommandsRequested.Proceed := FALSE;
CommandsRequested.Stop := FALSE;
CommandsRequested.CompleteState := FALSE;
CommandsRequested.Start := TRUE;
Start := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Stop" Id="{c1234567-1234-1234-1234-12345678C007}">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD Stop : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Safety command - skip source check, skip fault check
IF Status.Stopped OR Status.Stopping THEN
    Stop := E_RpcMethodResponse.REJECTED_WRONG_STATE;
    RETURN;
END_IF;

// Execute
CommandsRequested.Abort := FALSE;
CommandsRequested.Home := FALSE;
CommandsRequested.Proceed := FALSE;
CommandsRequested.Start := FALSE;
CommandsRequested.Pause := FALSE;
CommandsRequested.CompleteState := FALSE;
CommandsRequested.Stop := TRUE;
Stop := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetNextStep" Id="{d4e5f6a7-b8c9-0123-def0-123456789abc}">
      <Declaration><![CDATA[METHOD SetNextStep
VAR_INPUT
    nStep : DINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_nextStep := nStep;]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetStepFault" Id="{e5f6a7b8-c9d0-1234-ef01-23456789abcd}">
      <Declaration><![CDATA[METHOD SetStepFault
VAR_INPUT
    bFault : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_activeStep.StatusStepFaulted := bFault;
IF bFault THEN
    _nextStep := StepInfo.CurrentStep + 1;
END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="ReportStepInfo" Id="{f6a7b8c9-d0e1-2345-f012-3456789abcde}">
      <Declaration><![CDATA[METHOD ReportStepInfo
VAR_INPUT
    sName : STRING(80);
    stPerms : ST_PermIntlk_cfg;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_activeStep.PermsHMI := stPerms;
_activeStep.PermsHMI.Name := sName;]]></ST>
      </Implementation>
    </Method>
