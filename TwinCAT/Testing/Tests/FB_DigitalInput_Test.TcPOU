<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.12">
  <POU Name="FB_DigitalInput_Test" Id="{b1c2d3e4-f5a6-7890-abcd-000000000900}" SpecialFunc="None">
    <Declaration><![CDATA[// Tests for FB_DigitalInput. The production FB keeps its hardware-linked
// `io` struct in a private VAR section, so tests drive the raw wire
// through FB_DigitalInput_Probe.SetRawInput() — an injection method that
// the probe subclass exposes without changing the production API.
//
// Each test calls SetRawInput() to simulate a physical transition, then
// invokes the cyclic body with inpQuality and asserts on fb.sts.
//
// Time-dependent paths (debounce) use PT = T#1S so _tonOn.Q / _tofOff.Q
// stay in their pre-elapsed branch for the duration of the synchronous
// test, keeping assertions deterministic without real-time waits.
//
// The BadQuality fault itself requires real time on the watchdog TON and
// is covered by FB_DeviceBase_Test at the fault-bookkeeping level.
FUNCTION_BLOCK FB_DigitalInput_Test EXTENDS TcUnit.FB_TestSuite]]></Declaration>
    <Implementation>
      <ST><![CDATA[InitialStateClean();
RawSignalPassthroughWithNoDebounce();
InvertFlipsDebouncedValueNotRaw();
RisingEdgePulseOneScan();
FallingEdgePulseOneScan();
DebounceOnBlocksRisingEdgeUntilElapsed();
DebounceOffHoldsSignalHighAfterRawGoesLow();
BadQualityHoldsLastRawValue();
QualityTagSurfacesInStatus();
ClampedQualityReadsAsGood();]]></ST>
    </Implementation>
    <Method Name="InitialStateClean" Id="{b1c2d3e4-f5a6-7890-abcd-000000000901}">
      <Declaration><![CDATA[METHOD InitialStateClean
VAR
    fb : FB_DigitalInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('InitialStateClean');

fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertFalse(
    Condition := fb.sts.value,
    Message   := 'Fresh instance must read LOW when the physical input is LOW');
AssertFalse(
    Condition := fb.sts.rawValue,
    Message   := 'Fresh instance must report the raw input LOW');
AssertFalse(
    Condition := fb.sts.risingEdge,
    Message   := 'Fresh instance must not emit a spurious rising edge');
AssertFalse(
    Condition := fb.sts.fallingEdge,
    Message   := 'Fresh instance must not emit a spurious falling edge');
AssertFalse(
    Condition := fb.sts.header.faulted,
    Message   := 'Fresh instance must not be faulted');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="RawSignalPassthroughWithNoDebounce" Id="{b1c2d3e4-f5a6-7890-abcd-000000000902}">
      <Declaration><![CDATA[METHOD RawSignalPassthroughWithNoDebounce
VAR
    fb : FB_DigitalInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('RawSignalPassthroughWithNoDebounce');

// Default cfg: no debounce, no invert. Raw hardware bit flushes through
// to value in one cycle.
fb.SetRawInput(bValue := TRUE);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertTrue(
    Condition := fb.sts.rawValue,
    Message   := 'rawValue must echo the hardware bit under GOOD quality');
AssertTrue(
    Condition := fb.sts.value,
    Message   := 'With no debounce and no invert the conditioned value must match the raw bit');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="InvertFlipsDebouncedValueNotRaw" Id="{b1c2d3e4-f5a6-7890-abcd-000000000903}">
      <Declaration><![CDATA[METHOD InvertFlipsDebouncedValueNotRaw
VAR
    fb : FB_DigitalInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('InvertFlipsDebouncedValueNotRaw');

// Invert must apply to the debounced / published value but the raw
// reading should stay true-to-the-wire so troubleshooters can see what
// the hardware is actually doing.
fb.cfg.invert := TRUE;
fb.SetRawInput(bValue := TRUE);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertTrue(
    Condition := fb.sts.rawValue,
    Message   := 'rawValue must echo the wire value independent of invert');
AssertFalse(
    Condition := fb.sts.value,
    Message   := 'invert must flip the conditioned value (active-low sensor semantics)');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="RisingEdgePulseOneScan" Id="{b1c2d3e4-f5a6-7890-abcd-000000000904}">
      <Declaration><![CDATA[METHOD RisingEdgePulseOneScan
VAR
    fb : FB_DigitalInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('RisingEdgePulseOneScan');

fb.SetRawInput(bValue := FALSE);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

fb.SetRawInput(bValue := TRUE);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);
AssertTrue(
    Condition := fb.sts.risingEdge,
    Message   := 'risingEdge must fire on the cycle the debounced value goes HIGH');

fb(inpQuality := TcForge.E_IO_Quality.GOOD);
AssertFalse(
    Condition := fb.sts.risingEdge,
    Message   := 'risingEdge must clear the very next cycle — edges are one-scan pulses');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="FallingEdgePulseOneScan" Id="{b1c2d3e4-f5a6-7890-abcd-000000000905}">
      <Declaration><![CDATA[METHOD FallingEdgePulseOneScan
VAR
    fb : FB_DigitalInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('FallingEdgePulseOneScan');

fb.SetRawInput(bValue := TRUE);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

fb.SetRawInput(bValue := FALSE);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);
AssertTrue(
    Condition := fb.sts.fallingEdge,
    Message   := 'fallingEdge must fire on the cycle the debounced value goes LOW');

fb(inpQuality := TcForge.E_IO_Quality.GOOD);
AssertFalse(
    Condition := fb.sts.fallingEdge,
    Message   := 'fallingEdge must clear the very next cycle');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="DebounceOnBlocksRisingEdgeUntilElapsed" Id="{b1c2d3e4-f5a6-7890-abcd-000000000906}">
      <Declaration><![CDATA[METHOD DebounceOnBlocksRisingEdgeUntilElapsed
VAR
    fb : FB_DigitalInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('DebounceOnBlocksRisingEdgeUntilElapsed');

// debounceOn = T#1S — the _tonOn.Q won't fire inside this test frame.
fb.cfg.debounceOn := T#1S;
fb.SetRawInput(bValue := TRUE);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertTrue(
    Condition := fb.sts.rawValue,
    Message   := 'rawValue must still show the raw bit — debounce gates the conditioned value, not the raw view');
AssertFalse(
    Condition := fb.sts.value,
    Message   := 'debounceOn must hold value LOW until the TON elapses');
AssertFalse(
    Condition := fb.sts.risingEdge,
    Message   := 'No rising edge must be emitted while debounce is pending');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="DebounceOffHoldsSignalHighAfterRawGoesLow" Id="{b1c2d3e4-f5a6-7890-abcd-000000000907}">
      <Declaration><![CDATA[METHOD DebounceOffHoldsSignalHighAfterRawGoesLow
VAR
    fb : FB_DigitalInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('DebounceOffHoldsSignalHighAfterRawGoesLow');

// debounceOff = T#1S. With debounceOn still 0 we latch the
// debounced signal HIGH immediately, then flip the raw bit LOW and
// expect the TOF to hold the debounced value HIGH.
fb.cfg.debounceOff := T#1S;
fb.SetRawInput(bValue := TRUE);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);
AssertTrue(
    Condition := fb.sts.value,
    Message   := 'Precondition: raw HIGH with zero ON-debounce must latch the debounced value HIGH');

fb.SetRawInput(bValue := FALSE);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertFalse(
    Condition := fb.sts.rawValue,
    Message   := 'rawValue must immediately mirror the wire going LOW');
AssertTrue(
    Condition := fb.sts.value,
    Message   := 'debounceOff must hold the debounced value HIGH until the TOF expires');
AssertFalse(
    Condition := fb.sts.fallingEdge,
    Message   := 'No falling edge must be emitted while the OFF-debounce is pending');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="BadQualityHoldsLastRawValue" Id="{b1c2d3e4-f5a6-7890-abcd-000000000908}">
      <Declaration><![CDATA[METHOD BadQualityHoldsLastRawValue
VAR
    fb : FB_DigitalInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('BadQualityHoldsLastRawValue');

// Latch a known-good HIGH reading.
fb.SetRawInput(bValue := TRUE);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);
AssertTrue(
    Condition := fb.sts.rawValue,
    Message   := 'Precondition: under GOOD quality rawValue mirrors the wire');

// Simulate wire break: the underlying bit flips FALSE but quality is BAD.
// The FB must ignore the glitchy reading and hold the last-known-good raw.
fb.SetRawInput(bValue := FALSE);
fb(inpQuality := TcForge.E_IO_Quality.BAD);

AssertTrue(
    Condition := fb.sts.rawValue,
    Message   := 'BAD quality must freeze rawValue at the last known-good reading');
AssertEquals_USINT(
    Expected := TcForge.E_IO_Quality.BAD,
    Actual   := fb.sts.quality,
    Message  := 'quality must surface the BAD tag so downstream consumers can react');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="QualityTagSurfacesInStatus" Id="{b1c2d3e4-f5a6-7890-abcd-000000000909}">
      <Declaration><![CDATA[METHOD QualityTagSurfacesInStatus
VAR
    fb : FB_DigitalInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('QualityTagSurfacesInStatus');

// UNKNOWN -> BAD -> GOOD must each land in sts.quality unchanged so
// the HMI can display the exact tag the caller supplied.
fb(inpQuality := TcForge.E_IO_Quality.UNKNOWN);
AssertEquals_USINT(
    Expected := TcForge.E_IO_Quality.UNKNOWN,
    Actual   := fb.sts.quality,
    Message  := 'quality must surface UNKNOWN unchanged');

fb(inpQuality := TcForge.E_IO_Quality.BAD);
AssertEquals_USINT(
    Expected := TcForge.E_IO_Quality.BAD,
    Actual   := fb.sts.quality,
    Message  := 'quality must surface BAD unchanged');

fb(inpQuality := TcForge.E_IO_Quality.GOOD);
AssertEquals_USINT(
    Expected := TcForge.E_IO_Quality.GOOD,
    Actual   := fb.sts.quality,
    Message  := 'quality must surface GOOD unchanged');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="ClampedQualityReadsAsGood" Id="{b1c2d3e4-f5a6-7890-abcd-00000000090a}">
      <Declaration><![CDATA[METHOD ClampedQualityReadsAsGood
VAR
    fb : FB_DigitalInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('ClampedQualityReadsAsGood');

// The quality gate treats GOOD and CLAMPED as "trust the raw reading".
// CLAMPED is meant for analog signals that hit a scaling limit — for a
// digital input it has to behave the same as GOOD so a wrapper that
// passes CLAMPED through doesn't accidentally freeze the reading.
fb.SetRawInput(bValue := TRUE);
fb(inpQuality := TcForge.E_IO_Quality.CLAMPED);

AssertTrue(
    Condition := fb.sts.rawValue,
    Message   := 'CLAMPED quality must be treated like GOOD for raw readings');
AssertTrue(
    Condition := fb.sts.value,
    Message   := 'CLAMPED quality must not freeze the conditioned value');
AssertEquals_USINT(
    Expected := TcForge.E_IO_Quality.CLAMPED,
    Actual   := fb.sts.quality,
    Message  := 'quality must still surface CLAMPED so consumers know the raw came from a clamped source');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
