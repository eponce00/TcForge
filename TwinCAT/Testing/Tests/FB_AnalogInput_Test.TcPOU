<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.12">
  <POU Name="FB_AnalogInput_Test" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e00}" SpecialFunc="None">
    <Declaration><![CDATA[// Tests for FB_AnalogInput. The production FB keeps its hardware-linked
// `io` UNION in a private VAR section, so tests drive the raw bytes via
// FB_AnalogInput_Probe (SetRawInt / SetRawReal / SetRawDInt). The probe
// delegates the cyclic body to SUPER^() so the inherited conditioning
// pipeline runs against the injected value.
//
// Pipeline under test (from the production FB):
//     UNION raw -> type select -> quality gate -> clamp to scaling range
//     -> linear EU scaling -> optional LPF -> sts
//
// Scope: all synchronous conditioning behaviour. Time-dependent paths
// (qualityFaultAfter watchdog, filterTau smoothing over many
// samples) are already covered by FB_DeviceBase_Test and
// FB_LPF_FirstOrder_IIR_Test respectively.
FUNCTION_BLOCK FB_AnalogInput_Test EXTENDS TcUnit.FB_TestSuite
VAR CONSTANT
    TOL : REAL := 1E-3;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[InitialStatusPublishesDefaults();
LinearScalingMapsEndpointsAndMidpoint();
RawBypassSkipsClampAndScaling();
ClampLowReportsAndHoldsAtRawMin();
ClampHighReportsAndHoldsAtRawMax();
ClampPromotesGoodQualityToClamped();
ClampAsFaultRaisesClampLow();
ClampAsFaultRaisesClampHigh();
BadConfigRaisesFaultOnFirstScan();
BadQualityHoldsLastRawReading();
InputTypeRealReadsRealMemberOfUnion();
QualityTagPropagatesToStatus();]]></ST>
    </Implementation>
    <Method Name="InitialStatusPublishesDefaults" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e01}">
      <Declaration><![CDATA[METHOD InitialStatusPublishesDefaults
VAR
    fb : FB_AnalogInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('InitialStatusPublishesDefaults');

// Default cfg: INT terminal, raw 0..32767 -> EU 0..100 %, no filter,
// clamp-as-fault disabled. With io.inRaw zero-initialised the first
// cycle must report a clean 0 % and no fault.
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertTrue(
    Condition := ABS(fb.sts.value) < TOL,
    Message   := 'Fresh instance must publish value = 0 for a raw input of 0');
AssertTrue(
    Condition := ABS(fb.sts.rawReal) < TOL,
    Message   := 'Fresh instance must publish rawReal = 0');
AssertFalse(
    Condition := fb.sts.clampActive,
    Message   := 'Raw 0 is inside [0, 32767] so clampActive must be FALSE');
AssertFalse(
    Condition := fb.sts.header.faulted,
    Message   := 'Fresh instance must not be faulted');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="LinearScalingMapsEndpointsAndMidpoint" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e02}">
      <Declaration><![CDATA[METHOD LinearScalingMapsEndpointsAndMidpoint
VAR
    fb : FB_AnalogInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('LinearScalingMapsEndpointsAndMidpoint');

// Default cfg: raw 0..32767 -> EU 0..100. Verify the two endpoints and
// the midpoint land where the linear recurrence says they should.
//
//     value = euMin + (raw - rawMin)
//                           * (euMax - euMin)
//                           / (rawMax - rawMin)

fb.SetRawInt(nValue := 0);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);
AssertTrue(
    Condition := ABS(fb.sts.value - 0.0) < TOL,
    Message   := 'Raw = rawMin must map to euMin (0 %)');

fb.SetRawInt(nValue := 32767);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);
AssertTrue(
    Condition := ABS(fb.sts.value - 100.0) < TOL,
    Message   := 'Raw = rawMax must map to euMax (100 %)');

fb.SetRawInt(nValue := 16384);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);
AssertTrue(
    Condition := ABS(fb.sts.value - 50.0015) < 0.01,
    Message   := 'Raw ~ midpoint must map to EU ~ 50 %');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="RawBypassSkipsClampAndScaling" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e03}">
      <Declaration><![CDATA[METHOD RawBypassSkipsClampAndScaling
VAR
    fb : FB_AnalogInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('RawBypassSkipsClampAndScaling');

// useRawValue = TRUE publishes the raw REAL directly and suppresses
// the clamp flags even when the raw value is outside the scaling range.
fb.cfg.useRawValue := TRUE;
fb.SetRawInt(nValue := 30000);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertTrue(
    Condition := ABS(fb.sts.value - fb.sts.rawReal) < TOL,
    Message   := 'With useRawValue = TRUE, value must equal rawReal');
AssertFalse(
    Condition := fb.sts.clampedLow,
    Message   := 'Raw bypass must not flag clampedLow');
AssertFalse(
    Condition := fb.sts.clampedHigh,
    Message   := 'Raw bypass must not flag clampedHigh');
AssertFalse(
    Condition := fb.sts.clampActive,
    Message   := 'Raw bypass must not flag clampActive');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="ClampLowReportsAndHoldsAtRawMin" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e04}">
      <Declaration><![CDATA[METHOD ClampLowReportsAndHoldsAtRawMin
VAR
    fb : FB_AnalogInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('ClampLowReportsAndHoldsAtRawMin');

// Drive the raw INT below rawMin. The clamp must flag clampedLow
// and pin the scaled value at euMin.
fb.SetRawInt(nValue := -500);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertTrue(
    Condition := fb.sts.clampedLow,
    Message   := 'Raw below rawMin must set clampedLow');
AssertTrue(
    Condition := fb.sts.clampActive,
    Message   := 'clampActive must be TRUE whenever either clamp direction is active');
AssertTrue(
    Condition := ABS(fb.sts.value - 0.0) < TOL,
    Message   := 'Clamped-low output must pin to euMin (0 %)');
AssertFalse(
    Condition := fb.sts.header.faulted,
    Message   := 'clampAsFault = FALSE by default; clamp alone must not fault the device');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="ClampHighReportsAndHoldsAtRawMax" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e05}">
      <Declaration><![CDATA[METHOD ClampHighReportsAndHoldsAtRawMax
VAR
    fb : FB_AnalogInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('ClampHighReportsAndHoldsAtRawMax');

// Use REAL input so we can inject a raw that is clearly above rawMax
// (INT saturates at 32767; REAL doesn't).
fb.cfg.inputType := __SYSTEM.TYPE_CLASS.TYPE_REAL;
fb.SetRawReal(fValue := 40000.0);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertTrue(
    Condition := fb.sts.clampedHigh,
    Message   := 'Raw above rawMax must set clampedHigh');
AssertTrue(
    Condition := fb.sts.clampActive,
    Message   := 'clampActive must be TRUE when clampedHigh is set');
AssertTrue(
    Condition := ABS(fb.sts.value - 100.0) < TOL,
    Message   := 'Clamped-high output must pin to euMax (100 %)');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="ClampPromotesGoodQualityToClamped" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e06}">
      <Declaration><![CDATA[METHOD ClampPromotesGoodQualityToClamped
VAR
    fb : FB_AnalogInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('ClampPromotesGoodQualityToClamped');

// When the raw input is clamping *and* inpQuality = GOOD, the FB must
// promote quality to CLAMPED to signal "reading is legal but pinned".
fb.SetRawInt(nValue := -1);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertTrue(
    Condition := fb.sts.clampActive,
    Message   := 'Precondition: clampActive must be TRUE');
AssertEquals_DINT(
    Expected := TO_DINT(TcForge.E_IO_Quality.CLAMPED),
    Actual   := TO_DINT(fb.sts.quality),
    Message  := 'GOOD quality must be promoted to CLAMPED while clamping');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="ClampAsFaultRaisesClampLow" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e07}">
      <Declaration><![CDATA[METHOD ClampAsFaultRaisesClampLow
VAR
    fb : FB_AnalogInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('ClampAsFaultRaisesClampLow');

fb.cfg.clampAsFault := TRUE;
fb.SetRawInt(nValue := -10);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertTrue(
    Condition := fb.sts.header.faulted,
    Message   := 'clampAsFault + raw below RawMin must fault the device');
AssertEquals_DINT(
    Expected := TcForge.E_AnalogInput_Fault.ClampLow,
    Actual   := fb.sts.header.faultCode,
    Message  := 'Fault code must be ClampLow');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="ClampAsFaultRaisesClampHigh" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e08}">
      <Declaration><![CDATA[METHOD ClampAsFaultRaisesClampHigh
VAR
    fb : FB_AnalogInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('ClampAsFaultRaisesClampHigh');

fb.cfg.clampAsFault := TRUE;
fb.cfg.inputType    := __SYSTEM.TYPE_CLASS.TYPE_REAL;
fb.SetRawReal(fValue := 50000.0);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertTrue(
    Condition := fb.sts.header.faulted,
    Message   := 'clampAsFault + raw above RawMax must fault the device');
AssertEquals_DINT(
    Expected := TcForge.E_AnalogInput_Fault.ClampHigh,
    Actual   := fb.sts.header.faultCode,
    Message  := 'Fault code must be ClampHigh');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="BadConfigRaisesFaultOnFirstScan" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e09}">
      <Declaration><![CDATA[METHOD BadConfigRaisesFaultOnFirstScan
VAR
    fb : FB_AnalogInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('BadConfigRaisesFaultOnFirstScan');

// BadConfig check runs once on the first scan. Set rawMin >= rawMax
// BEFORE the first cyclic call so the validation can latch _configBad.
fb.cfg.rawMin := 100.0;
fb.cfg.rawMax := 100.0;
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertTrue(
    Condition := fb.sts.header.faulted,
    Message   := 'rawMin >= rawMax must fault the device as BadConfig');
AssertEquals_DINT(
    Expected := TcForge.E_AnalogInput_Fault.BadConfig,
    Actual   := fb.sts.header.faultCode,
    Message  := 'Fault code must be BadConfig');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="BadQualityHoldsLastRawReading" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e0a}">
      <Declaration><![CDATA[METHOD BadQualityHoldsLastRawReading
VAR
    fb          : FB_AnalogInput_Probe;
    snapshotRaw : REAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('BadQualityHoldsLastRawReading');

// Establish a good reading first.
fb.SetRawInt(nValue := 10000);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);
snapshotRaw := fb.sts.rawReal;

// Flip quality to BAD and change the raw wire. The FB must discard the
// fresh value and hold the last-known-good raw reading.
fb.SetRawInt(nValue := 25000);
fb(inpQuality := TcForge.E_IO_Quality.BAD);

AssertTrue(
    Condition := ABS(fb.sts.rawReal - snapshotRaw) < TOL,
    Message   := 'BAD quality must hold rawReal at the last-known-good value');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="InputTypeRealReadsRealMemberOfUnion" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e0b}">
      <Declaration><![CDATA[METHOD InputTypeRealReadsRealMemberOfUnion
VAR
    fb : FB_AnalogInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('InputTypeRealReadsRealMemberOfUnion');

// Select the REAL UNION member and reconfigure scaling so raw == EU,
// then confirm the FB reads the REAL alias rather than some other
// reinterpretation of the same bytes.
fb.cfg.inputType := __SYSTEM.TYPE_CLASS.TYPE_REAL;
fb.cfg.rawMin    := 0.0;
fb.cfg.rawMax    := 100.0;
fb.cfg.euMin     := 0.0;
fb.cfg.euMax     := 100.0;

fb.SetRawReal(fValue := 42.5);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);

AssertTrue(
    Condition := ABS(fb.sts.rawReal - 42.5) < TOL,
    Message   := 'TYPE_REAL must read io.inRaw.fReal directly into rawReal');
AssertTrue(
    Condition := ABS(fb.sts.value - 42.5) < TOL,
    Message   := 'Identity scaling must leave value equal to the raw REAL input');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="QualityTagPropagatesToStatus" Id="{b1c2d3e4-f5a6-7890-abcd-000000000e0c}">
      <Declaration><![CDATA[METHOD QualityTagPropagatesToStatus
VAR
    fb : FB_AnalogInput_Probe;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('QualityTagPropagatesToStatus');

// The FB must echo inpQuality into sts.quality each cycle (subject to
// the clamp promotion covered by ClampPromotesGoodQualityToClamped).
fb.SetRawInt(nValue := 10000);
fb(inpQuality := TcForge.E_IO_Quality.GOOD);
AssertEquals_DINT(
    Expected := TO_DINT(TcForge.E_IO_Quality.GOOD),
    Actual   := TO_DINT(fb.sts.quality),
    Message  := 'quality must mirror inpQuality = GOOD when not clamping');

fb(inpQuality := TcForge.E_IO_Quality.UNKNOWN);
AssertEquals_DINT(
    Expected := TO_DINT(TcForge.E_IO_Quality.UNKNOWN),
    Actual   := TO_DINT(fb.sts.quality),
    Message  := 'quality must mirror inpQuality = UNKNOWN');

fb(inpQuality := TcForge.E_IO_Quality.BAD);
AssertEquals_DINT(
    Expected := TO_DINT(TcForge.E_IO_Quality.BAD),
    Actual   := TO_DINT(fb.sts.quality),
    Message  := 'quality must mirror inpQuality = BAD');

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
