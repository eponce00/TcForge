<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.12">
  <POU Name="FB_AnalogOutput" Id="{a0100004-0000-0000-0000-000000000001}" SpecialFunc="None">
    <Declaration><![CDATA[// Generic analog output driver.
//
// Pipeline:
//   SetValue -> persistent command -> clamp to MinCv/MaxCv -> EU-to-raw
//   linear scaling -> UNION write (type chosen by cfg.outputType)
//
// Command is persisted so an unexpected PLC restart resumes the last
// requested setpoint rather than quietly writing 0 to the field device.
{attribute 'OPC.UA.DA' := '1'}
FUNCTION_BLOCK FB_AnalogOutput EXTENDS FB_DeviceBase
VAR_INPUT
    {attribute 'OPC.UA.DA' := '1'}
    {attribute 'OPC.UA.DA.Access' := '1'}
    cfg        : ST_AnalogOutput_Cfg;
    {attribute 'OPC.UA.DA' := '0'}
    inpQuality : E_IO_Quality := E_IO_Quality.GOOD;
END_VAR

VAR_OUTPUT
    {attribute 'OPC.UA.DA' := '1'}
    {attribute 'OPC.UA.DA.Access' := '1'}
    sts : ST_AnalogOutput_Sts;
END_VAR

VAR PERSISTENT
    // Last commanded value (EU). Survives power cycle.
    {attribute 'OPC.UA.DA' := '0'}
    _requestSync : REAL;
END_VAR

VAR
    // Hardware-linked struct (UNION; dw member AT %Q*). Wired at instance
    // declaration with
    //   {attribute 'TcLinkTo' := '.io.outRaw.dw := TIID^...'}.
    {attribute 'OPC.UA.DA' := '0'}
    io             : ST_AnalogOutput_IO;

    // Commissioning state.
    {attribute 'OPC.UA.DA' := '0'}
    _firstScan     : BOOL := TRUE;
    {attribute 'OPC.UA.DA' := '0'}
    _configBad     : BOOL;

    // Quality watchdog.
    {attribute 'OPC.UA.DA' := '0'}
    _tonBadQuality : TON;

    // Scratch values.
    {attribute 'OPC.UA.DA' := '0'}
    _clampedEu     : REAL;
    {attribute 'OPC.UA.DA' := '0'}
    _rawReal       : REAL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[// 1. First-scan config validation.
IF _firstScan THEN
    _firstScan := FALSE;
    _configBad := (NOT cfg.useRawValue)
                  AND (cfg.euMax - cfg.euMin = 0.0 OR cfg.rawMin > cfg.rawMax);
END_IF;

sts.unit       := cfg.unit;
sts.quality    := inpQuality;
sts.commanded  := _requestSync;

// 2. Clamp the command in EU space.
sts.clampedLow  := FALSE;
sts.clampedHigh := FALSE;
_clampedEu         := _requestSync;

IF NOT cfg.useRawValue THEN
    IF _clampedEu < cfg.minCv THEN
        _clampedEu        := cfg.minCv;
        sts.clampedLow := TRUE;
    ELSIF _clampedEu > cfg.maxCv THEN
        _clampedEu         := cfg.maxCv;
        sts.clampedHigh := TRUE;
    END_IF;
END_IF;
sts.clampActive := sts.clampedLow OR sts.clampedHigh;
sts.value       := _clampedEu;

// 3. Scale EU -> raw (or pass through if useRawValue).
IF cfg.useRawValue THEN
    _rawReal := _clampedEu;
ELSIF (cfg.euMax - cfg.euMin) <> 0.0 THEN
    _rawReal := cfg.rawMin
              + (cfg.rawMax - cfg.rawMin)
                * ((_clampedEu - cfg.euMin) / (cfg.euMax - cfg.euMin));
ELSE
    _rawReal := 0.0;
END_IF;
sts.rawReal := _rawReal;

// 4. Write the UNION member matching cfg.outputType. BAD quality holds
//    the previously-written value by simply skipping the write.
IF inpQuality = E_IO_Quality.GOOD OR inpQuality = E_IO_Quality.CLAMPED THEN
    CASE cfg.outputType OF
        __SYSTEM.TYPE_CLASS.TYPE_INT:   io.outRaw.nInt := REAL_TO_INT(_rawReal);
        __SYSTEM.TYPE_CLASS.TYPE_UINT:  io.outRaw.ui   := REAL_TO_UINT(_rawReal);
        __SYSTEM.TYPE_CLASS.TYPE_WORD:  io.outRaw.w    := REAL_TO_WORD(_rawReal);
        __SYSTEM.TYPE_CLASS.TYPE_DINT:  io.outRaw.di   := REAL_TO_DINT(_rawReal);
        __SYSTEM.TYPE_CLASS.TYPE_UDINT: io.outRaw.udi  := REAL_TO_UDINT(_rawReal);
        __SYSTEM.TYPE_CLASS.TYPE_DWORD: io.outRaw.dw   := REAL_TO_DWORD(_rawReal);
    ELSE
        io.outRaw.fReal := _rawReal;
    END_CASE;
END_IF;

// 5. Quality watchdog.
_tonBadQuality(
    IN := inpQuality = E_IO_Quality.BAD AND cfg.qualityFaultAfter > T#0MS,
    PT := cfg.qualityFaultAfter
);

// 6. Single-source-of-truth fault raise.
_RaiseActiveFault();

// 7. Refresh shared header.
_UpdateHeader(header := sts.header, stateString := '', busy := FALSE);]]></ST>
    </Implementation>
    <Folder Name="Public" Id="{a0100004-0000-0000-f000-000000000001}" />
    <Folder Name="Protected" Id="{a0100004-0000-0000-f000-000000000002}" />
    <Method Name="SetValue" Id="{a0100004-0000-0000-1000-000000000001}" FolderPath="Public\">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD PUBLIC SetValue : E_RpcMethodResponse
VAR_INPUT
    rValue     : REAL;
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[SetValue := F_ValidateRequester(
    eRequester    := eRequester,
    bSourceLocked := bSourceLockedToProg,
    bFaulted      := IsFaulted()
);

IF SetValue <> E_RpcMethodResponse.ACCEPTED THEN
    RETURN;
END_IF;

_requestSync := rValue;
_AcceptCommand(eRequester := eRequester);]]></ST>
      </Implementation>
    </Method>
    <Method Name="_RaiseActiveFault" Id="{a0100004-0000-0000-1000-000000000002}" FolderPath="Protected\">
      <Declaration><![CDATA[// Priority chain for AnalogOutput faults:
//   BadConfig > BadQuality > ClampHigh > ClampLow
METHOD PROTECTED _RaiseActiveFault
VAR
    code   : DINT;
    source : STRING(31);
    reason : STRING(79);
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[code := 0;

IF _configBad THEN
    code   := E_AnalogOutput_Fault.BadConfig;
    source := 'CONFIG';
    reason := 'euMin >= euMax or rawMin > rawMax';
ELSIF _tonBadQuality.Q THEN
    code   := E_AnalogOutput_Fault.BadQuality;
    source := 'QUALITY';
    reason := 'inpQuality stayed BAD past qualityFaultAfter';
ELSIF cfg.clampAsFault AND sts.clampedHigh THEN
    code   := E_AnalogOutput_Fault.ClampHigh;
    source := 'CLAMP_H';
    reason := CONCAT('Command clamped at MaxCv=', REAL_TO_STRING(cfg.maxCv));
ELSIF cfg.clampAsFault AND sts.clampedLow THEN
    code   := E_AnalogOutput_Fault.ClampLow;
    source := 'CLAMP_L';
    reason := CONCAT('Command clamped at MinCv=', REAL_TO_STRING(cfg.minCv));
END_IF;

IF code = 0 THEN
    IF IsFaulted() THEN
        _ClearFault();
    END_IF;
ELSE
    _Raise(
        code   := code,
        source := source,
        reason := reason
    );
END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="ResolveFaultString" Id="{a0100004-0000-0000-1000-000000000003}" FolderPath="Protected\">
      <Declaration><![CDATA[METHOD PROTECTED ResolveFaultString : STRING(79)
VAR_INPUT
    code : DINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE code OF
    0:
        ResolveFaultString := '';
    E_AnalogOutput_Fault.BadQuality:
        ResolveFaultString := 'Output quality BAD past configured timeout';
    E_AnalogOutput_Fault.ClampLow:
        ResolveFaultString := 'Command clamped at MinCv';
    E_AnalogOutput_Fault.ClampHigh:
        ResolveFaultString := 'Command clamped at MaxCv';
    E_AnalogOutput_Fault.BadConfig:
        ResolveFaultString := 'Invalid scaling range configured';
ELSE
    ResolveFaultString := CONCAT('AnalogOutput fault ', DINT_TO_STRING(code));
END_CASE;]]></ST>
      </Implementation>
    </Method>
    <LineIds Name="FB_AnalogOutput">
      <LineId Id="1" Count="0" />
    </LineIds>
    <LineIds Name="FB_AnalogOutput.SetValue">
      <LineId Id="1" Count="0" />
    </LineIds>
    <LineIds Name="FB_AnalogOutput._RaiseActiveFault">
      <LineId Id="1" Count="0" />
    </LineIds>
    <LineIds Name="FB_AnalogOutput.ResolveFaultString">
      <LineId Id="1" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>
