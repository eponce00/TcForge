<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.12">
  <POU Name="FB_TwoPosActuator" Id="{a1234567-1234-1234-1234-123456789007}" SpecialFunc="None">
    <Declaration><![CDATA[{attribute 'OPC.UA.DA' := '1'}
FUNCTION_BLOCK FB_TwoPosActuator EXTENDS FB_DeviceBase
VAR_INPUT
    {attribute 'OPC.UA.DA' := '1'}
    {attribute 'OPC.UA.DA.Access' := '1'}
    cfg : ST_TwoPosActuator_Cfg;
END_VAR

VAR_OUTPUT
    {attribute 'OPC.UA.DA' := '1'}
    {attribute 'OPC.UA.DA.Access' := '1'}
    sts : ST_TwoPosActuator_Sts;
END_VAR

VAR
    // Allocated I/O struct. The AT %I* / %Q* primitives inside ST_TwoPosActuator_IO
    // are linked at the FB instance declaration using {attribute 'TcLinkTo' := ...}
    // — see docs/5-IO-Binding.md. The struct is VAR (not VAR_IN_OUT) so the FB
    // owns its wiring and callers don't need to pass an external struct.
    {attribute 'OPC.UA.DA' := '0'}
    io : ST_TwoPosActuator_IO;

    // Composed permissive handlers (visible on OPC under the FB instance).
    advancePermissives : FB_Permissives;
    retractPermissives : FB_Permissives;

    // Internal state tracking
    {attribute 'OPC.UA.DA' := '0'}
    currentState : E_TwoPosActuator_State := E_TwoPosActuator_State.Undefined;
    {attribute 'OPC.UA.DA' := '0'}
    previousState : E_TwoPosActuator_State;

    // Motion timers
    {attribute 'OPC.UA.DA' := '0'}
    advanceTimer : TON;
    {attribute 'OPC.UA.DA' := '0'}
    retractTimer : TON;

    // Edge detection for one-shot outputs
    {attribute 'OPC.UA.DA' := '0'}
    rTrigAdvanced : R_TRIG;
    {attribute 'OPC.UA.DA' := '0'}
    rTrigRetracted : R_TRIG;

    {attribute 'OPC.UA.DA' := '0'}
    bothFeedbackActive : BOOL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[//-----------------------------------------------------------------------------
// Cyclic monitoring. Commands are issued via methods; this body only watches
// for completion/faults and keeps sts in sync. Fault latching + last-fault
// history live in FB_DeviceBase (_Raise / _ClearFault).
//-----------------------------------------------------------------------------
advancePermissives();
retractPermissives();

bothFeedbackActive := io.inFbkAdvanced AND io.inFbkRetracted;

previousState := currentState;

CASE currentState OF

    E_TwoPosActuator_State.Undefined:
        io.outValveAdvance := FALSE;
        io.outValveRetract := FALSE;

        IF bothFeedbackActive THEN
            currentState := E_TwoPosActuator_State.Fault;
            _Raise(
                code   := E_TwoPosActuator_Fault.BothFeedbackOn,
                source := 'FEEDBACK',
                reason := 'Both advanced and retracted feedback asserted simultaneously'
            );
        ELSIF io.inFbkAdvanced AND NOT io.inFbkRetracted THEN
            currentState := E_TwoPosActuator_State.Advanced;
        ELSIF io.inFbkRetracted AND NOT io.inFbkAdvanced THEN
            currentState := E_TwoPosActuator_State.Retracted;
        END_IF;

    E_TwoPosActuator_State.Retracted:
        IF cfg.holdAtRetracted THEN
            io.outValveRetract := TRUE;
        ELSE
            io.outValveRetract := FALSE;
        END_IF;
        io.outValveAdvance := FALSE;

        IF bothFeedbackActive THEN
            currentState := E_TwoPosActuator_State.Fault;
            _Raise(
                code   := E_TwoPosActuator_Fault.BothFeedbackOn,
                source := 'FEEDBACK',
                reason := 'Both advanced and retracted feedback asserted simultaneously'
            );
        ELSIF NOT io.inFbkRetracted THEN
            currentState := E_TwoPosActuator_State.Fault;
            _Raise(
                code   := E_TwoPosActuator_Fault.UndefinedState,
                source := 'FEEDBACK',
                reason := 'Retracted feedback lost after reaching position'
            );
        END_IF;

    E_TwoPosActuator_State.Advancing:
        io.outValveAdvance := TRUE;
        io.outValveRetract := FALSE;
        advanceTimer(IN := TRUE, PT := DINT_TO_TIME(cfg.advTimeoutS * 1000));

        IF io.inFbkAdvanced AND NOT io.inFbkRetracted THEN
            currentState := E_TwoPosActuator_State.Advanced;
            advanceTimer(IN := FALSE);
        ELSIF advanceTimer.Q THEN
            currentState := E_TwoPosActuator_State.Fault;
            _Raise(
                code   := E_TwoPosActuator_Fault.AdvanceTimeout,
                source := 'MOTION',
                reason := 'inFbkAdvanced did not assert within advTimeoutS'
            );
            advanceTimer(IN := FALSE);
        ELSIF bothFeedbackActive THEN
            currentState := E_TwoPosActuator_State.Fault;
            _Raise(
                code   := E_TwoPosActuator_Fault.BothFeedbackOn,
                source := 'FEEDBACK',
                reason := 'Both advanced and retracted feedback asserted while advancing'
            );
            advanceTimer(IN := FALSE);
        ELSIF NOT advancePermissives.sts.bOK THEN
            currentState := E_TwoPosActuator_State.Fault;
            _Raise(
                code   := E_TwoPosActuator_Fault.PermissivesNotOK,
                source := 'PERMISSIVES',
                reason := 'Advance permissive dropped during travel'
            );
            advanceTimer(IN := FALSE);
        END_IF;

    E_TwoPosActuator_State.Advanced:
        IF cfg.holdAtAdvanced THEN
            io.outValveAdvance := TRUE;
        ELSE
            io.outValveAdvance := FALSE;
        END_IF;
        io.outValveRetract := FALSE;

        IF bothFeedbackActive THEN
            currentState := E_TwoPosActuator_State.Fault;
            _Raise(
                code   := E_TwoPosActuator_Fault.BothFeedbackOn,
                source := 'FEEDBACK',
                reason := 'Both advanced and retracted feedback asserted simultaneously'
            );
        ELSIF NOT io.inFbkAdvanced THEN
            currentState := E_TwoPosActuator_State.Fault;
            _Raise(
                code   := E_TwoPosActuator_Fault.UndefinedState,
                source := 'FEEDBACK',
                reason := 'Advanced feedback lost after reaching position'
            );
        END_IF;

    E_TwoPosActuator_State.Retracting:
        io.outValveRetract := TRUE;
        io.outValveAdvance := FALSE;
        retractTimer(IN := TRUE, PT := DINT_TO_TIME(cfg.retTimeoutS * 1000));

        IF io.inFbkRetracted AND NOT io.inFbkAdvanced THEN
            currentState := E_TwoPosActuator_State.Retracted;
            retractTimer(IN := FALSE);
        ELSIF retractTimer.Q THEN
            currentState := E_TwoPosActuator_State.Fault;
            _Raise(
                code   := E_TwoPosActuator_Fault.RetractTimeout,
                source := 'MOTION',
                reason := 'inFbkRetracted did not assert within retTimeoutS'
            );
            retractTimer(IN := FALSE);
        ELSIF bothFeedbackActive THEN
            currentState := E_TwoPosActuator_State.Fault;
            _Raise(
                code   := E_TwoPosActuator_Fault.BothFeedbackOn,
                source := 'FEEDBACK',
                reason := 'Both advanced and retracted feedback asserted while retracting'
            );
            retractTimer(IN := FALSE);
        ELSIF NOT retractPermissives.sts.bOK THEN
            currentState := E_TwoPosActuator_State.Fault;
            _Raise(
                code   := E_TwoPosActuator_Fault.PermissivesNotOK,
                source := 'PERMISSIVES',
                reason := 'Retract permissive dropped during travel'
            );
            retractTimer(IN := FALSE);
        END_IF;

    E_TwoPosActuator_State.Fault:
        io.outValveAdvance := FALSE;
        io.outValveRetract := FALSE;
        advanceTimer(IN := FALSE);
        retractTimer(IN := FALSE);
END_CASE;

//-------------------------------------------------------------------------
// Device-specific status
//-------------------------------------------------------------------------
sts.state        := currentState;
sts.advanced  := (currentState = E_TwoPosActuator_State.Advanced);
sts.retracted := (currentState = E_TwoPosActuator_State.Retracted);
sts.moving    := (currentState = E_TwoPosActuator_State.Advancing) OR
                    (currentState = E_TwoPosActuator_State.Retracting);

rTrigAdvanced(CLK := sts.advanced);
sts.osAdvanced := rTrigAdvanced.Q;

rTrigRetracted(CLK := sts.retracted);
sts.osRetracted := rTrigRetracted.Q;

//-------------------------------------------------------------------------
// Common header — delegated to the base; fault/source/timestamps filled from
// the inherited fault book-keeping and source lock. busy mirrors sts.moving.
//-------------------------------------------------------------------------
_UpdateHeader(
    header      := sts.header,
    stateString := _StateToString(state := currentState),
    busy     := sts.moving
);]]></ST>
    </Implementation>
    <Folder Name="Public" Id="{f0a10001-0001-0001-0001-000000000001}" />
    <Folder Name="Private" Id="{f0a10002-0001-0001-0001-000000000002}" />
    <Method Name="Advance" Id="{a1234567-1234-1234-1234-12345678A001}" FolderPath="Public\">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD PUBLIC Advance : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[Advance := F_ValidateRequester(eRequester, bSourceLockedToProg, IsFaulted());
IF Advance <> E_RpcMethodResponse.ACCEPTED THEN RETURN; END_IF;

IF currentState = E_TwoPosActuator_State.Advanced OR currentState = E_TwoPosActuator_State.Advancing THEN
    Advance := E_RpcMethodResponse.REJECTED_ALREADY_AT_TARGET;
    RETURN;
END_IF;

IF NOT advancePermissives.sts.bOK THEN
    Advance := E_RpcMethodResponse.REJECTED_PERMISSIVE_NOT_MET;
    RETURN;
END_IF;

currentState := E_TwoPosActuator_State.Advancing;
advanceTimer(IN := FALSE);
_AcceptCommand(eRequester := eRequester);
Advance := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Retract" Id="{a1234567-1234-1234-1234-12345678A002}" FolderPath="Public\">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
METHOD PUBLIC Retract : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[Retract := F_ValidateRequester(eRequester, bSourceLockedToProg, IsFaulted());
IF Retract <> E_RpcMethodResponse.ACCEPTED THEN RETURN; END_IF;

IF currentState = E_TwoPosActuator_State.Retracted OR currentState = E_TwoPosActuator_State.Retracting THEN
    Retract := E_RpcMethodResponse.REJECTED_ALREADY_AT_TARGET;
    RETURN;
END_IF;

IF NOT retractPermissives.sts.bOK THEN
    Retract := E_RpcMethodResponse.REJECTED_PERMISSIVE_NOT_MET;
    RETURN;
END_IF;

currentState := E_TwoPosActuator_State.Retracting;
retractTimer(IN := FALSE);
_AcceptCommand(eRequester := eRequester);
Retract := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Abort" Id="{a1234567-1234-1234-1234-12345678A003}" FolderPath="Public\">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
// Safety command — always accepted (bypasses source lock and fault check).
// De-energizes both valves and returns to Undefined for re-evaluation.
METHOD PUBLIC Abort : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[io.outValveAdvance := FALSE;
io.outValveRetract := FALSE;
advanceTimer(IN := FALSE);
retractTimer(IN := FALSE);
currentState := E_TwoPosActuator_State.Undefined;
_AcceptCommand(eRequester := eRequester);
Abort := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Reset" Id="{a1234567-1234-1234-1234-12345678A004}" FolderPath="Public\">
      <Declaration><![CDATA[{attribute 'TcRpcEnable' := '1'}
// Safety invariant: Reset is always accepted from any requester regardless
// of source lock or current state. Clears the active fault via the base and
// returns the device to Undefined so the body can re-evaluate feedback.
METHOD PUBLIC Reset : E_RpcMethodResponse
VAR_INPUT
    eRequester : E_Requester := E_Requester.PROG;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[SUPER^.Reset(eRequester := eRequester);

currentState := E_TwoPosActuator_State.Undefined;
io.outValveAdvance := FALSE;
io.outValveRetract := FALSE;
advanceTimer(IN := FALSE);
retractTimer(IN := FALSE);
Reset := E_RpcMethodResponse.ACCEPTED;]]></ST>
      </Implementation>
    </Method>
    <Method Name="ResolveFaultString" Id="{a1234567-1234-1234-1234-12345678A005}" FolderPath="Private\">
      <Declaration><![CDATA[// Translates this device's fault enum to human-readable text.
// Called by FB_DeviceBase to populate sts.header.faultString / lastFaultString.
METHOD PROTECTED ResolveFaultString : STRING(79)
VAR_INPUT
    code : DINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE code OF
    E_TwoPosActuator_Fault.None:                ResolveFaultString := 'No Fault';
    E_TwoPosActuator_Fault.AdvanceTimeout:      ResolveFaultString := 'Advance Timeout';
    E_TwoPosActuator_Fault.RetractTimeout:      ResolveFaultString := 'Retract Timeout';
    E_TwoPosActuator_Fault.BothFeedbackOn:      ResolveFaultString := 'Both Feedbacks Active';
    E_TwoPosActuator_Fault.UndefinedState:      ResolveFaultString := 'Position Undefined';
    E_TwoPosActuator_Fault.PermissivesNotOK:    ResolveFaultString := 'Permissives Not OK';
    E_TwoPosActuator_Fault.ConflictingCommands: ResolveFaultString := 'Conflicting Commands';
    E_TwoPosActuator_Fault.NoFeedback:          ResolveFaultString := 'No Position Feedback';
ELSE
    ResolveFaultString := 'Unknown Fault';
END_CASE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="_StateToString" Id="{a1234567-1234-1234-1234-12345678A006}" FolderPath="Private\">
      <Declaration><![CDATA[METHOD PRIVATE _StateToString : STRING(31)
VAR_INPUT
    state : E_TwoPosActuator_State;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE state OF
    E_TwoPosActuator_State.Undefined:  _StateToString := 'Undefined';
    E_TwoPosActuator_State.Retracted:  _StateToString := 'Retracted';
    E_TwoPosActuator_State.Advancing:  _StateToString := 'Advancing';
    E_TwoPosActuator_State.Advanced:   _StateToString := 'Advanced';
    E_TwoPosActuator_State.Retracting: _StateToString := 'Retracting';
    E_TwoPosActuator_State.Fault:      _StateToString := 'Fault';
ELSE
    _StateToString := 'Unknown';
END_CASE;]]></ST>
      </Implementation>
    </Method>
    <LineIds Name="FB_TwoPosActuator">
