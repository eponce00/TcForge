<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.12">
  <POU Name="FB_Step" Id="{a1b2c3d4-e5f6-7890-abcd-ef1234567890}" SpecialFunc="None">
    <Declaration><![CDATA[(*
FB_Step - Lightweight step lifecycle wrapper
============================================
Each step in a sequence is one FB_Step instance. The parent FB_StateMachine
owns the active step number, step timer, fault detection, and command handling.
This FB only reports "am I active?" and drives the Entry/Execute/Exit/Advance
lifecycle for the user's code.

Lifecycle (while this step is the SM's active step):
  Entry   : TRUE one scan on activation         -> one-shot init
  Execute : TRUE every scan until perms satisfied -> cyclic work + MapPerm
  Exiting : TRUE one scan after perms satisfied  -> one-shot cleanup
  Advance : writes nNextStep to the SM, SM increments on next scan

Branching / looping / jumping:
  nNextStep is a VAR_INPUT re-evaluated every scan. To branch, loop, or jump,
  just assign nNextStep dynamically in the call. There is no separate override
  method -- the input IS the dynamic target.

      step(sm := sm, nStep := 3004,
           nNextStep := SEL(bPass, 3500, 3006),  // branch inline
           nTimeout := 12, sName := 'Inspect');

  nNextStep := 0   -> completes the sequence (SM transitions to waiting state)
  nNextStep := N   -> SM advances to step N (any valid step; forward/back)

Note: 'Exiting' is used instead of 'Exit' because EXIT is an IEC reserved word.
*)
FUNCTION_BLOCK FB_Step
VAR_IN_OUT
    sm : FB_StateMachine;
END_VAR

VAR_INPUT
    nStep : DINT;
    nNextStep : DINT;
    nTimeout : DINT;
    sName : STRING(40);
END_VAR

VAR_OUTPUT
    Entry : BOOL;
    Execute : BOOL;
    Exiting : BOOL;
END_VAR

VAR
    _perms : FB_Permissives;
    _active : BOOL;
    _prevActive : BOOL;
    _permsSatisfied : BOOL;
    _permsEvalReady : BOOL;
    _exitDone : BOOL;
    _timeoutFired : BOOL;       // guard: timeout fires at most once per activation
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[
// Evaluate permissives (unmapped bits automatically good)
_perms();
_permsSatisfied := _perms.sts.bOK;

// Check if this step is the active step in the state machine
_active := (sm.Status.Step.Current = nStep);

// Reset lifecycle outputs each scan
Entry := FALSE;
Execute := FALSE;
Exiting := FALSE;

IF _active THEN
    // Publish step name to SM for HMI / diagnostics
    sm.SetStepName(sName);
  sm.SetStepPermissives(cfg := _perms.cfg, sts := _perms.sts);

    IF NOT _prevActive THEN
        //---------------------------------------------------------------------
        // ENTRY: first scan this step is active
        //---------------------------------------------------------------------
        Entry := TRUE;
        _permsEvalReady := FALSE;
        _exitDone := FALSE;
        _timeoutFired := FALSE;

    ELSIF NOT _permsEvalReady THEN
        //---------------------------------------------------------------------
        // First EXECUTE scan: user is mapping perms this scan; evaluate next
        // scan so the first evaluation sees all MapPerm calls from this cycle.
        //---------------------------------------------------------------------
        Execute := TRUE;
        _permsEvalReady := TRUE;

    ELSIF NOT _permsSatisfied THEN
        //---------------------------------------------------------------------
        // EXECUTE: waiting for all mapped permissives to be satisfied
        //---------------------------------------------------------------------
        IF NOT sm.Status.Faulted THEN
            Execute := TRUE;
        END_IF;

        // Timeout fault detection: push StepTimeout through the fault handler
        // with a default "Step N [name]: Step Timeout" reason, then jump to
        // the odd fault step so the existing state-machine semantics still
        // apply. Guarded by _timeoutFired so the fault/advance only happen once.
        IF NOT _timeoutFired AND nTimeout > 0 AND
           sm.Status.Step.TimerSeconds > DINT_TO_REAL(nTimeout) THEN
            sm._RaiseStepFault(
                stepNum  := nStep,
                stepName := sName,
                code     := E_SM_Fault.StepTimeout,
                reason   := ''
            );
            sm.SetNextStep(nStep := nStep + 1);
            _timeoutFired := TRUE;
        END_IF;

    ELSIF NOT _exitDone THEN
        //---------------------------------------------------------------------
        // EXIT: all permissives satisfied, one-scan cleanup
        //---------------------------------------------------------------------
        Exiting := TRUE;
        _exitDone := TRUE;

    ELSE
        //---------------------------------------------------------------------
        // ADVANCE: post-exit, hand the (current-scan) nNextStep to the SM.
        // Because nNextStep is re-evaluated every scan, the user's latest
        // branch decision wins -- no override method needed.
        //---------------------------------------------------------------------
        sm.SetNextStep(nStep := nNextStep);
    END_IF;

ELSE
    // Reset lifecycle tracking when step is not active
    _permsEvalReady := FALSE;
    _exitDone := FALSE;
    _timeoutFired := FALSE;
END_IF;

_prevActive := _active;
]]></ST>
    </Implementation>
    <Folder Name="Public" Id="{f0b10001-0001-0001-0001-000000000001}" />
    <Method Name="MapPerm" Id="{b2c3d4e5-f6a7-8901-bcde-f12345678901}" FolderPath="Public\">
      <Declaration><![CDATA[METHOD MapPerm
VAR_INPUT
    nIndex : UDINT;
    sDescription : STRING;
    bValue : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_perms.MapInput(bitIndex := nIndex, inputValue := bValue);
_perms.cfg.aNames[nIndex] := sDescription;]]></ST>
      </Implementation>
    </Method>
    <Method Name="RaiseFault" Id="{b2c3d4e5-f6a7-8901-bcde-f12345678902}" FolderPath="Public\">
      <Declaration><![CDATA[// Called from inside a step body to record a device fault with a specific
// code and a human-readable reason, then advance to the odd fault step
// (nStep + 1) so the state-machine fault convention still applies.
//
// Idempotent within a step activation: multiple calls in the same scan (or
// the same fault episode across scans) push only the first entry onto the
// ring per-code (the base FB's _Raise dedupes on code). Calling with a
// different code overwrites current and pushes a new ring entry.
//
// Example:
//   IF step3004.Execute AND NOT sensorOK THEN
//       step3004.RaiseFault(
//           code   := E_SM_Fault.StepUserFault,
//           reason := 'Sensor A reports out-of-range reading 42.7 bar'
//       );
//   END_IF;
//
// C0371 is the "VAR_IN_OUT accessed from method" warning. Safe here because
// RaiseFault is only legal inside a step block, after FB_Step() has been
// called with a valid sm reference.
METHOD RaiseFault
VAR_INPUT
    code   : DINT;
    reason : STRING(79);
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[{warning disable C0371}
IF NOT _active THEN
    RETURN;
END_IF;

sm._RaiseStepFault(
    stepNum  := nStep,
    stepName := sName,
    code     := code,
    reason   := reason
);
sm.SetNextStep(nStep := nStep + 1);
{warning restore C0371}]]></ST>
      </Implementation>
    </Method>
    <LineIds Name="FB_Step">
      <LineId Id="1" Count="0" />
    </LineIds>
    <LineIds Name="FB_Step.MapPerm">
      <LineId Id="1" Count="0" />
    </LineIds>
    <LineIds Name="FB_Step.RaiseFault">
      <LineId Id="1" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>